---
/**
 * moment-lab.astro — preview harness for the moment islands.
 *
 * NOT part of production nav / IA. This page exists only so the
 * `redesign/moment-hero` branch can preview <MomentHero /> in isolation
 * (dark pole). It is intentionally minimal — no site Header/Footer chrome —
 * so the moment is the only thing on the stage. Do not link it from the nav
 * or ship it in the launch swap; the home page mounts <MomentHero /> for real.
 */
import '../styles/global.css';
import MomentHero from '../components/moments/MomentHero.astro';
import MomentGraph from '../components/moments/MomentGraph.astro';
---

<!doctype html>
<html lang="en" data-theme="A" data-mode="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>Moment lab · MomentHero (dark pole)</title>
		<meta name="description" content="Internal preview harness for the proving-moment island. Not production nav." />
	</head>
	<body class="sk-page">
		<main id="main-content">
			<MomentHero tone="dark" autoplay="viewport" />
			<!-- SPIKE-07 — capability-graph moment island feasibility spike -->
			<MomentGraph tone="dark" />
		</main>
	</body>
</html>
