---
// /packages — the ecosystem storefront (WP-17, plan L3).
//
// Registry-driven: the "All packages" index is generated at build time from
// the published registry (src/lib/registry.ts — live fetch + committed
// snapshot fallback so the CF Pages build never breaks). Every depicted pkg
// is registry-real; the six unpublished app pkgs appear only in a labelled
// "Coming" strip with no install affordance (G-21 / DEC-1). Card system is
// typographic-first per DEC-2 (no per-pkg art yet — the logo-forge track
// upgrades these later).
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import BrandIcon from '../../components/BrandIcon.astro';
import {
	loadRegistry,
	groupByKind,
	label,
	oneLine,
	installCmd,
	comingPkgs,
	type RegistryPkg,
} from '../../lib/registry';

const { index: registry, source } = await loadRegistry();
const grouped = groupByKind(registry);
const coming = comingPkgs(registry);

// Flagship detail pages that exist under /packages/* (registry-real pkgs with
// hand-authored prose). Rows link here when a flagship page exists.
const DETAIL_LINKS: Record<string, string> = {
	'@ikenga/pkg-tasks': '/packages/tasks',
	'@ikenga/mcp-iyke': '/packages/mcp-iyke',
	'@ikenga/pkg-engine-claude-code': '/packages/engines',
	'@ikenga/pkg-engine-codex': '/packages/engines',
	'@ikenga/pkg-engine-gemini': '/packages/engines',
};

// "Coming" pkgs that already have a hand-authored preview page under /packages/*.
// Keyed by the short `ComingPkg.name` (not the scoped registry id). A preview
// link is honest here — the page itself is framed "coming to the registry".
const COMING_DETAIL_LINKS: Record<string, string> = {
	studio: '/packages/studio',
};

// Per-engine brand glyph for the generated rows.
const engineIcon = (name: string): string | null =>
	name.includes('claude') ? 'claude' : name.includes('gemini') ? 'gemini' : name.includes('codex') ? 'codex' : null;

// Two co-equal on-ramps (G-21 / R5-5). Skills are portable primitives: they
// run anywhere in plain Claude Code AND move across engines — install once via
// npx, use with or without the shell. Packages install + update inside the shell.
const SKILLS_ONRAMP = [
	{ name: 'Groundwork', icons: ['claude', 'npm'], line: 'A research → plan → act workflow scaffold. Runs in plain Claude Code via npx — and gets a live board view in the shell.', href: '/packages/groundwork', install: 'npx skills add royalti-io/groundwork' },
	{ name: 'Artifacts', icons: ['claude', 'npm'], line: 'Author self-contained interactive HTML artifacts that render anywhere — then review, compare, and promote them in the shell.', href: '/packages/artifacts', install: 'npx skills add royalti-io/ikenga-artifact-builder' },
];
const PKG_ONRAMP = [
	{ name: 'Tasks', icons: [] as string[], line: 'A local-first task manager that lives inside your workspace — lists, triage, and agenda in one pane.', href: '/packages/tasks' },
	{ name: 'mcp-iyke', icons: ['claude'], line: 'Give any MCP client — Claude, Cursor, or your own tool — live control over the running shell.', href: '/packages/mcp-iyke' },
	{ name: 'Engines', icons: ['claude', 'gemini', 'codex'], line: 'Claude Code is the default. Gemini and Codex are pluggable adapters — same setup, different engine.', href: '/packages/engines' },
];

const updated = new Date(registry.updatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const title = 'Packages for Ikenga — install and update like apps';
const desc = "Browse what's published for your Claude Code setup — mini-apps, MCP tool servers, engine adapters, and skills. The catalog is generated live from the registry; only what's actually published appears here.";
---

<Layout title={title} description={desc} canonical="https://ikenga.dev/packages/">
	<section class="sk-hero">
		<div class="sk-wrap">
			<p class="sk-eyebrow">Packages</p>
			<h1 class="sk-display">Install and update like <em>apps.</em></h1>
			<p class="sk-lede">
				Everything that extends your Claude Code setup — mini-apps, MCP tool
				servers, engine adapters — is a package. Some, like our skills, also run
				anywhere in plain Claude Code with no shell at all, and move with you
				across engines.
			</p>
			<p class="sk-body">
				Two ways in: install and update packages inside the shell, or add a
				skill via <code>npx</code> and use it with or without Ikenga. The catalog
				below is generated from the registry — only what's actually published
				appears here.
			</p>
		</div>
	</section>

	<!-- Featured strip (editorial) — the two co-equal on-ramps (G-21):
	     skills that work anywhere and move across engines, and packages you
	     install in the shell. -->
	<section class="sk-section">
		<div class="sk-wrap">
			<h2 class="sk-h2">Two ways in</h2>

			<h3 class="pk-cat__head">
				Skills <span class="pk-cat__blurb">— portable primitives: run anywhere via <code>npx</code>, move across engines</span>
			</h3>
			<div class="sk-grid">
				{SKILLS_ONRAMP.map((f) => (
					<Card title={f.name} href={f.href} tag="no shell">
						{f.icons.length > 0 && (
							<span class="pk-onramp-icons">{f.icons.map((n) => <BrandIcon name={n} />)}</span>
						)}
						{f.line}
						<br /><code class="pk-cmd">{f.install}</code>
					</Card>
				))}
			</div>

			<h3 class="pk-cat__head" style="margin-top: var(--space-8);">
				Packages <span class="pk-cat__blurb">— install and update inside the shell</span>
			</h3>
			<div class="sk-grid">
				{PKG_ONRAMP.map((f) => (
					<Card title={f.name} href={f.href} tag="in shell">
						{f.icons.length > 0 && (
							<span class="pk-onramp-icons">{f.icons.map((n) => <BrandIcon name={n} />)}</span>
						)}
						{f.line}
					</Card>
				))}
			</div>
		</div>
	</section>

	<!-- Generated index -->
	<section class="sk-section">
		<div class="sk-wrap">
			<h2 class="sk-h2">All packages</h2>
			<p class="sk-body pk-meta">
				Generated from the registry · Last published {updated}{source === 'snapshot' ? ' · from committed snapshot' : ''} · install commands
				require the <a href="/#install">Ikenga shell</a>.
			</p>
			{grouped.map((cat) => (
				<div class="pk-cat">
					<h3 class="pk-cat__head">{cat.key} <span class="pk-cat__blurb">— {cat.blurb}</span></h3>
					<ul class="pk-rows">
						{cat.rows.map((p: RegistryPkg) => (
							<li class="pk-row">
								<div class="pk-row__top">
									{engineIcon(p.name) && <BrandIcon name={engineIcon(p.name) as string} />}
									<code class="pk-row__id">{label(p.name)}</code>
									<span class="pk-row__ver">v{p.latest}</span>
								</div>
								<p class="pk-row__desc">{oneLine(p.description)}</p>
								<div class="pk-row__foot">
									<code class="pk-cmd">{installCmd(p)}</code>
									{DETAIL_LINKS[p.name] && <a class="pk-row__doc" href={DETAIL_LINKS[p.name]}>Details →</a>}
								</div>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</section>

	<!-- Coming strip — built in ikenga-pkgs, not yet published to the registry.
	     Labelled, no install affordance, no version claim (G-21 / DEC-1). The
	     list self-corrects: anything the registry now publishes drops off here
	     and shows in the catalog above instead. -->
	{coming.length > 0 && (
		<section class="sk-section">
			<div class="sk-wrap">
				<h2 class="sk-h2">Coming to the registry</h2>
				<p class="sk-body pk-meta">
					Built and in the shell — not yet published, so no install command
					here yet. They'll appear in the catalog above the moment they ship.
				</p>
				<div class="sk-grid">
					{coming.map((p) => (
						<div class="sk-card pk-soon">
							<span class="sk-card__tag">Coming</span>
							<h3 class="sk-card__title">{p.name}</h3>
							<p class="sk-card__body">{p.line}</p>
							{COMING_DETAIL_LINKS[p.name] && <a class="pk-row__doc pk-soon__doc" href={COMING_DETAIL_LINKS[p.name]}>Preview →</a>}
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<section class="sk-section">
		<div class="sk-wrap">
			<Button href="/docs/" variant="ghost">Read the docs</Button>
		</div>
	</section>
</Layout>

<style>
	.pk-meta {
		color: var(--site-faint);
		font-size: 0.875rem;
	}
	.pk-meta a {
		color: var(--site-accent);
	}
	.pk-cat {
		margin-top: var(--space-8);
	}
	.pk-cat__head {
		font-family: var(--site-font-display);
		font-size: 1.125rem;
		font-weight: 600;
		margin: 0 0 var(--space-4);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--site-border-soft);
	}
	.pk-cat__blurb {
		color: var(--site-muted);
		font-weight: 400;
		font-size: 0.9375rem;
	}
	.pk-rows {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: var(--space-3);
	}
	.pk-row {
		border: 1px solid var(--site-border);
		border-radius: var(--radius-lg, 10px);
		background: var(--site-surface);
		padding: var(--space-4) var(--space-5);
	}
	.pk-row__top {
		display: flex;
		align-items: baseline;
		gap: var(--space-3);
	}
	.pk-row__id {
		font-family: var(--site-font-mono);
		font-size: 0.9375rem;
		color: var(--site-fg);
	}
	.pk-row__ver {
		font-family: var(--site-font-mono);
		font-size: 0.75rem;
		color: var(--site-accent);
	}
	.pk-row__desc {
		color: var(--site-muted);
		font-size: 0.9375rem;
		margin: var(--space-2) 0 var(--space-3);
		max-width: var(--site-measure-body);
	}
	.pk-cmd {
		display: inline-block;
		font-family: var(--site-font-mono);
		font-size: 0.8125rem;
		color: var(--site-fg);
		background: var(--site-bg);
		border: 1px solid var(--site-border-strong);
		border-radius: var(--radius-sm, 4px);
		padding: var(--space-1) var(--space-3);
	}
	.pk-row__foot {
		display: flex;
		align-items: center;
		gap: var(--space-4);
		margin-top: var(--space-2);
		flex-wrap: wrap;
	}
	.pk-row__doc {
		font-size: 0.8125rem;
		color: var(--site-accent);
		text-decoration: none;
	}
	.pk-row__doc:hover {
		text-decoration: underline;
	}
	.pk-soon {
		/* WP-21 a11y gate: opacity-dimming the whole card dropped the tag/body
		   text below 4.5:1 (LH measures the composited color). De-emphasize with
		   a dashed border + muted title instead — text keeps full contrast. */
		border-style: dashed;
	}
	.pk-soon .sk-card__title {
		color: var(--site-muted);
	}
	.pk-soon__doc {
		display: inline-block;
		margin-top: var(--space-3);
	}
	.pk-onramp-icons {
		display: inline-flex;
		gap: var(--space-2);
		align-items: center;
		margin-right: var(--space-2);
		vertical-align: -0.1em;
	}
</style>
