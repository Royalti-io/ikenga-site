---
// /newsletter — "Building in the Loop." Founder-written, biweekly.
// WP-01 of plans/2026-07-02-community-content-engine/. WP-02 flips the
// Discord block visible by swapping DISCORD_INVITE.
import Layout from '../layouts/Layout.astro';

const SUBSCRIBE_URL = 'https://buildingintheloop.substack.com/subscribe';
const DISCORD_INVITE = '{{DISCORD_INVITE}}'; // TODO(WP-02): replace with the Discord invite link to flip this visible
const DISCORD_LIVE = Boolean(DISCORD_INVITE) && !DISCORD_INVITE.startsWith('{{');

const title = 'Building in the Loop — Ikenga’s newsletter for Claude Code builders';
const description =
	'Biweekly letters from a founder running a real, in-production Claude Code system — 28 agents, 101 skills, 68 commands. Real workflows, real costs, build-in-public.';
---

<Layout title={title} description={description} canonical="https://ikenga.dev/newsletter">

	<!-- Hero + subscribe -->
	<section class="sk-hero sk-section--flush">
		<div class="sk-wrap">
			<p class="sk-eyebrow">Building in the Loop · Biweekly · Founder-written</p>
			<h1 class="sk-display">Building in the <em>Loop.</em></h1>
			<p class="sk-lede">
				I run a real, in-production Claude Code system every day — 28 agents, 101 skills, 68
				commands, doing actual work across a live company. This is the letter where I show how it's
				built: the workflows that hold up, the ones that broke, and what it actually costs to run
				agents like this in production. Build-in-public, no gloss.
			</p>

			<form class="nl-form" action={SUBSCRIBE_URL} method="get" target="_blank">
				<label class="sk-sr-only" for="nl-email">Email address</label>
				<input
					id="nl-email"
					class="nl-form__input"
					type="email"
					name="email"
					placeholder="you@email.com"
					required
					autocomplete="email"
				/>
				<button type="submit" class="sk-btn sk-btn--primary nl-form__submit">Subscribe</button>
			</form>
			<p class="nl-form__note">No spam. Unsubscribe anytime.</p>
		</div>
	</section>

	<!-- What you'll get -->
	<section class="sk-section">
		<div class="sk-wrap">
			<h2 class="sk-h2">What you'll get</h2>
			<ul class="sk-list">
				<li>
					A <strong>biweekly issue</strong> that alternates between a workflow deep-dive (one agent,
					one skill, one automation — how it's actually wired) and a build-in-public note on
					what shipped, what broke, and what it cost.
				</li>
				<li>
					A <strong>monthly screen-recorded tutorial</strong> that walks through one real workflow
					end to end, as a companion to that issue.
				</li>
				<li>
					Links to what's landing in the <strong>Ikenga OSS</strong> repo as it ships —
					agents, skills, and packages, straight from the source.
				</li>
			</ul>
		</div>
	</section>

	<!-- Discord (hidden until WP-02 sets DISCORD_INVITE) -->
	{DISCORD_LIVE && (
		<section class="sk-section">
			<div class="sk-wrap">
				<h2 class="sk-h2">Talk shop between issues</h2>
				<p class="sk-body">
					Want to compare notes with other agent builders between issues?
					<a href={DISCORD_INVITE}>Join the Discord</a>.
				</p>
			</div>
		</section>
	)}

</Layout>

<style>
	.sk-sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.nl-form {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		max-width: 30rem;
		flex-wrap: wrap;
		margin: var(--space-6) 0 var(--space-3);
	}
	.nl-form__input {
		flex: 1 1 14rem;
		min-width: 0;
		padding: var(--space-3) var(--space-4);
		background: var(--site-surface);
		border: 1px solid var(--site-border-strong);
		border-radius: var(--radius-md, 6px);
		color: var(--site-fg);
		font-family: var(--site-font-body);
		font-size: 0.9375rem;
	}
	.nl-form__input::placeholder {
		color: var(--site-faint, var(--site-muted));
	}
	.nl-form__input:focus-visible {
		outline: 2px solid var(--site-accent);
		outline-offset: 2px;
	}
	.nl-form__submit {
		flex: none;
	}
	.nl-form__note {
		font-size: 0.8125rem;
		color: var(--site-faint, var(--site-muted));
		font-style: italic;
		margin: 0 0 var(--space-2);
	}
</style>
