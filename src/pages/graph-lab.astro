---
/**
 * graph-lab.astro — preview harness for <MomentGraph /> (WP-07).
 *
 * NOT part of production nav / IA. Mirrors moment-lab.astro's role but is
 * dedicated to the capability-graph island so both tone poles can be
 * verified side by side without touching moment-lab.astro (which is
 * MomentHero's own harness) or index.astro (which mounts the dark-pole
 * production instance for real). Do not link this from the nav or ship it
 * in the launch swap.
 */
import '../styles/global.css';
import MomentGraph from '../components/moments/MomentGraph.astro';
---

<!doctype html>
<html lang="en" data-theme="A" data-mode="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>Graph lab · MomentGraph (both tones)</title>
		<meta
			name="description"
			content="Internal preview harness for the capability-graph moment island. Not production nav."
		/>
	</head>
	<body class="sk-page">
		<main id="main-content">
			<!-- Dark pole -->
			<MomentGraph tone="dark" />

			<!-- Light pole — the `tone` prop sets [data-tone="light"] on the
			     island's own root section (WP-02 convention); the stage inside
			     stays the fixed dark object per CONTRACT.md regardless. -->
			<MomentGraph tone="light" />
		</main>
	</body>
</html>
