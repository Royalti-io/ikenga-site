---
/**
 * moment-lab-2.astro — preview harness for the WP-06 moment pair.
 *
 * NOT part of production nav / IA. Exists only so `redesign/home` can
 * preview <MomentTasks /> and <MomentInstall /> in isolation (dark pole)
 * while WP-10 decides real page placement. Mirrors `moment-lab.astro`'s
 * minimal shell (no site Header/Footer chrome). Do not link it from the nav
 * or ship it in the launch swap.
 */
import '../styles/global.css';
import MomentTasks from '../components/moments/MomentTasks.astro';
import MomentInstall from '../components/moments/MomentInstall.astro';
---

<!doctype html>
<html lang="en" data-theme="A" data-mode="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>Moment lab 2 · MomentTasks + MomentInstall (dark pole)</title>
		<meta name="description" content="Internal preview harness for the WP-06 moment pair. Not production nav." />
	</head>
	<body class="sk-page">
		<main id="main-content">
			<MomentTasks tone="dark" autoplay="viewport" />
			<MomentInstall tone="dark" autoplay="viewport" />
		</main>
	</body>
</html>
