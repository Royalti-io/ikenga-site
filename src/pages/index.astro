---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MomentHero from '../components/moments/MomentHero.astro';
import MomentTasks from '../components/moments/MomentTasks.astro';
import MomentInstall from '../components/moments/MomentInstall.astro';
import MomentGraph from '../components/moments/MomentGraph.astro';
import InstallSection from '../components/sections/InstallSection.astro';
import ObiSection from '../components/sections/ObiSection.astro';
import castData from '../components/moments/cast.json';

// Home shell & narrative assembly (plans/site-redesign, Phase 2, WP-10 —
// assembles the WP-05 scaffold with the WP-06/07/08/09 fan-out). Inverted
// narrative locked at D-01 (theatre hero, hard tonal seam): moment →
// watch-it-work → everything-connects → packages-teaser (light) → install
// (light) → Obi (dark) → subscribe (light).
//
// Copy accounting vs the prior index.astro (full text in git history, this
// branch's parent commit): every G-21 claim that doesn't survive verbatim
// below is either re-flowed (new location noted inline) or moved into one
// of the section components above — see each WP's report for its
// accounting.
const GITHUB = 'https://github.com/Royalti-io/ikenga';
const storeRows = castData.store_rows;
---

<!doctype html>
<html lang="en" data-theme="A" data-mode="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Ikenga — give Claude Code a home</title>
		<meta
			name="description"
			content="The open-source, local-first desktop home for your Claude Code setup. Skills like groundwork and artifact-builder run anywhere in plain Claude Code — and get a visual home in Ikenga, alongside the packages you install and manage."
		/>
		<link rel="canonical" href="https://ikenga.dev/" />
		<!-- Open Graph / Twitter (WP-24 owns the canonical set; mirrored here) -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ikenga.dev/" />
		<meta property="og:title" content="Ikenga — give Claude Code a home" />
		<meta
			property="og:description"
			content="Skills that run anywhere in Claude Code, plus the packages you install and manage — all with a visual home. Open-source, local-first."
		/>
		<meta property="og:image" content="https://ikenga.dev/assets/shell/og-card.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="https://ikenga.dev/assets/shell/og-card.png" />
		<!-- Cloudflare Web Analytics -->
		<script
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon='{"token": "3fdcdf8ab9ba4ca68bd46410d1527108"}'></script>
	</head>
	<body class="sk-page">
		<Header github={GITHUB} />

		<main id="main-content">
			<!-- ═══════════════ 1. HERO (dark) — D-01 theatre ═══════════════
			     MomentHero renders its own <section>: eyebrow-less rotating-
			     agent H1, sub line, ghost links (#install / #skills), the
			     shell-recreation stage, and the honest "staged demo" caption —
			     exactly as the island provides (G-MOMENT locked). Nothing added
			     here; the outer copy consumes --site-* so it reads dark by
			     default at the page level. -->
			<MomentHero autoplay="viewport" />

			<!-- ═══════════════ 2. WATCH IT WORK (dark) ═══════════════
			     MomentTasks + MomentInstall (WP-06) — the tasks/agenda beat
			     and the Ọba install beat, both on the shared timeline engine
			     (moments/timeline.ts). Each island renders its own <h2>, so
			     the section-level intro stays an eyebrow (no second h2) to
			     keep one heading per beat. -->
			<section class="wiw">
				<p class="sk-eyebrow wiw-eyebrow">Watch it work</p>
				<MomentTasks tone="dark" autoplay="viewport" />
				<MomentInstall tone="dark" autoplay="viewport" />
			</section>

			<!-- ═══════════════ 3. EVERYTHING CONNECTS (dark) ═══════════════
			     MomentGraph renders its own heading ("Everything connects."),
			     lede, and the capability-graph stage as a self-contained
			     section (WP-07 production pass over SPIKE-07). -->
			<MomentGraph tone="dark" />

			<!-- ═══════════════ 4. PACKAGES TEASER (light — hard tonal seam) ═══════════════
			     Typographic cards straight off the cast's store_rows fixture
			     (name / version / one-liner) — re-flows the old page's
			     "Everything is a package" beat as a teaser strip; no art yet
			     (storefront art is a Phase-3 track). -->
			<section class="sk-section" data-tone="light">
				<div class="sk-wrap">
					<h2 class="sk-h2">Everything is a <em>package.</em></h2>
					<p class="sk-lede">
						Mini-apps, tool servers, engine adapters — every capability docks
						into your workspace as an independently installable package.
						Add what you need, retire what you don't.
					</p>
					<div class="sk-grid pkg-grid">
						{storeRows.map((pkg) => (
							<div class="pkg-card">
								<p class="pkg-card__name">
									{pkg.name}
									<span class="pkg-card__version">v{pkg.version}</span>
								</p>
								<p class="pkg-card__desc">{pkg.description}</p>
							</div>
						))}
					</div>
					<p class="pkg-teaser__more">
						<a href="/packages/">Browse all packages →</a>
					</p>
				</div>
			</section>

			<!-- ═══════════════ 5. INSTALL (light) ═══════════════ -->
			<InstallSection />

			<!-- ═══════════════ 6. OBI (dark) ═══════════════ -->
			<ObiSection />

			<!-- ═══════════════ 7. SUBSCRIBE (light) — lifted verbatim ═══════════════
			     Live production code (WP-29): the form markup, the honeypot,
			     and the /api/subscribe wiring below are unchanged from the
			     prior index.astro — do not rewrite the logic. -->
			<section class="sk-section" data-tone="light">
				<form class="sk-wrap subscribe" id="subscribe-form" novalidate>
					<label class="subscribe-label" for="subscribe-email">
						Get the <em>ozi</em> — dispatches when Ikenga ships: releases, new
						packages, and notes from the build.
					</label>
					<div class="subscribe-row">
						<input
							id="subscribe-email"
							name="email"
							type="email"
							inputmode="email"
							autocomplete="email"
							placeholder="you@example.com"
							aria-describedby="subscribe-msg"
							required
						/>
						<button type="submit" id="subscribe-btn">Subscribe</button>
					</div>
					<!-- honeypot: hidden from humans, catches bots -->
					<input
						class="subscribe-hp"
						type="text"
						name="company"
						tabindex="-1"
						autocomplete="off"
						aria-hidden="true"
					/>
					<p class="subscribe-consent">
						No spam — just Ikenga updates. Unsubscribe anytime in one click.
					</p>
					<p class="subscribe-msg" id="subscribe-msg" role="status" aria-live="polite"></p>
				</form>
			</section>
		</main>

		<Footer github={GITHUB} />

		<script>
			// Subscribe form (WP-29) — posts to the Listmonk Pages Function.
			const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
			const emailEl = document.getElementById('subscribe-email') as HTMLInputElement | null;
			const btn = document.getElementById('subscribe-btn') as HTMLButtonElement | null;
			const msg = document.getElementById('subscribe-msg');

			form?.addEventListener('submit', async (e) => {
				e.preventDefault();
				if (!emailEl || !btn || !msg) return;
				const email = emailEl.value.trim();
				const company = (form.elements.namedItem('company') as HTMLInputElement)?.value ?? '';
				if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
					msg.textContent = 'Enter a valid email address.';
					msg.dataset.state = 'error';
					emailEl.setAttribute('aria-invalid', 'true');
					emailEl.focus();
					return;
				}
				emailEl.removeAttribute('aria-invalid');
				btn.disabled = true;
				const original = btn.textContent;
				btn.textContent = 'Subscribing…';
				msg.textContent = '';
				delete msg.dataset.state;
				try {
					const res = await fetch('/api/subscribe', {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({ email, company }),
					});
					const data = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };
					if (res.ok && data.ok) {
						form.reset();
						msg.textContent = "You're on the list. Welcome.";
						msg.dataset.state = 'ok';
					} else {
						msg.textContent = data.error ?? 'Could not subscribe right now. Please try again.';
						msg.dataset.state = 'error';
					}
				} catch {
					msg.textContent = 'Network error. Please try again.';
					msg.dataset.state = 'error';
				} finally {
					btn.disabled = false;
					btn.textContent = original;
				}
			});
		</script>

		<style>
			/* Page-specific layout — the kit (.sk-*) carries the visual language;
			   this only positions the watch-it-work seam, the packages teaser,
			   and the subscribe form for this landing instance. */
			html,
			body {
				margin: 0;
			}

			/* watch-it-work — thin wrapper around the two moment islands, each
			   of which owns its own padding/background (.mt / .mi); this only
			   carries the section eyebrow above the pair. */
			.wiw {
				display: block;
				background: var(--site-bg);
			}
			.wiw-eyebrow {
				max-width: 64rem;
				margin: 0 auto;
				padding: var(--space-8, 32px) var(--space-6, 24px) 0;
			}

			/* packages teaser cards — typographic, no art yet */
			.pkg-grid {
				margin-top: var(--space-6, 24px);
			}
			.pkg-card {
				border: 1px solid var(--site-border);
				border-radius: var(--radius-lg, 10px);
				padding: var(--space-5, 20px);
				background: var(--site-surface);
			}
			.pkg-card__name {
				font-family: var(--site-font-mono);
				font-weight: 600;
				font-size: 0.9375rem;
				color: var(--site-fg);
				margin: 0 0 var(--space-2, 8px);
			}
			.pkg-card__version {
				font-weight: 500;
				color: var(--site-accent);
				margin-left: var(--space-2, 8px);
			}
			.pkg-card__desc {
				font-size: 0.9375rem;
				color: var(--site-muted);
				margin: 0;
			}
			.pkg-teaser__more {
				margin-top: var(--space-6, 24px);
			}
			.pkg-teaser__more a {
				color: var(--site-accent);
				font-weight: 600;
				text-decoration: none;
			}
			.pkg-teaser__more a:hover {
				text-decoration: underline;
			}

			/* subscribe form */
			.subscribe {
				display: block;
			}
			.subscribe-label {
				display: block;
				font-size: 1.0625rem;
				color: var(--site-fg);
				max-width: var(--site-measure-body);
				margin-bottom: var(--space-4);
			}
			.subscribe-label em {
				color: var(--site-accent);
				font-style: italic;
			}
			.subscribe-row {
				display: flex;
				gap: var(--space-3);
				flex-wrap: wrap;
				max-width: 34rem;
			}
			.subscribe-row input {
				flex: 1;
				min-width: 14rem;
				padding: 11px 14px;
				border-radius: var(--radius-md, 6px);
				border: 1px solid var(--site-border);
				background: var(--site-surface);
				color: var(--site-fg);
				font: inherit;
				font-size: 0.9375rem;
			}
			.subscribe-row input:focus-visible {
				outline: 2px solid var(--site-accent);
				outline-offset: 1px;
			}
			.subscribe-row button {
				padding: 11px 20px;
				border-radius: var(--radius-md, 6px);
				border: 1px solid transparent;
				background: var(--site-accent);
				color: hsl(28, 30%, 8%);
				font: inherit;
				font-weight: 600;
				font-size: 0.9375rem;
				cursor: pointer;
				transition: filter 0.15s ease;
			}
			.subscribe-row button:hover {
				filter: brightness(1.08);
			}
			.subscribe-row button:focus-visible {
				outline: 2px solid var(--site-accent);
				outline-offset: 2px;
			}
			.subscribe-row button:disabled {
				opacity: 0.6;
				cursor: default;
			}
			.subscribe-hp {
				position: absolute;
				left: -9999px;
				width: 1px;
				height: 1px;
				opacity: 0;
			}
			.subscribe-consent {
				font-size: 0.8125rem;
				color: var(--site-faint);
				margin: var(--space-3) 0 0;
			}
			.subscribe-msg {
				font-size: 0.875rem;
				margin: var(--space-2) 0 0;
				min-height: 1.2em;
			}
			.subscribe-msg[data-state='ok'] {
				color: var(--site-success);
			}
			.subscribe-msg[data-state='error'] {
				color: var(--site-danger);
			}
		</style>
	</body>
</html>
