---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Downloads from '../components/Downloads.astro';
import BrandIcon from '../components/BrandIcon.astro';
import InstallBlock from '../components/InstallBlock.astro';
import ProofList from '../components/ProofList.astro';
import Beat from '../components/Beat.astro';

// WP-12 — broad-audience hero (G-21: the blend — "a home for your Claude Code
// setup, proven by skills doing real work"; two co-equal on-ramps). Refined
// from the G-20 cockpit-first lead the founder rejected (R5/R6, 2026-06-01).
// Visual language: site design system D-01 "Forge, tempered" — warm Dusk Wood,
// IM Fell serif display, deliberate kola-amber glow, disciplined --space-*
// rhythm. Consumes the .sk-* kit + --site-* tokens (plans/site-design-system).
// Both CTAs are LIVE: app install one-liner (WP-13, install.sh is x86_64-only,
// hence the caption) and the skills on-ramp (npx, verified public 2026-06-01).
const INSTALL = 'curl -fsSL https://ikenga.dev/install.sh | sh';
// Honest inventory (G-21): only groundwork + artifact-builder ship standalone
// today — atelier/video-studio are "coming", never claimed live-standalone.
const SKILL = 'npx skills add royalti-io/groundwork';
const GITHUB = 'https://github.com/Royalti-io/ikenga';
---

<!doctype html>
<html lang="en" data-theme="A" data-mode="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Ikenga — give Claude Code a home</title>
		<meta
			name="description"
			content="The open-source, local-first desktop home for your Claude Code setup. Skills like groundwork and artifact-builder run anywhere in plain Claude Code — and get a visual home in Ikenga, alongside the packages you install and manage."
		/>
		<link rel="canonical" href="https://ikenga.dev/" />
		<!-- Open Graph / Twitter (WP-24 owns the canonical set; mirrored here) -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ikenga.dev/" />
		<meta property="og:title" content="Ikenga — give Claude Code a home" />
		<meta
			property="og:description"
			content="Skills that run anywhere in Claude Code, plus the packages you install and manage — all with a visual home. Open-source, local-first."
		/>
		<meta property="og:image" content="https://ikenga.dev/assets/shell/og-card.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="https://ikenga.dev/assets/shell/og-card.png" />
		<!-- Cloudflare Web Analytics -->
		<script
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon='{"token": "3fdcdf8ab9ba4ca68bd46410d1527108"}'></script>
	</head>
	<body class="sk-page">
		<Header github={GITHUB} />

		<main id="main-content">
			<!-- ───────────────── Hero ───────────────── -->
			<section class="sk-hero">
				<div class="sk-wrap">
					<p class="sk-eyebrow">Ikenga</p>
					<h1 class="sk-display">Give Claude&nbsp;Code <em>a home.</em></h1>
					<p class="sk-lede">
						Skills like <strong>groundwork</strong> and <strong>artifact-builder</strong>
						run anywhere in plain Claude Code — and get a visual home in Ikenga,
						alongside the mini-apps and tools you install and manage like packages.
					</p>
					<p class="sk-body">
						See your whole Claude Code setup in one place and watch it do real
						work — live CLIs running in panes, boards tracking the job, artifacts
						taking shape — with no more hand-editing <code>~/.claude</code> dotfiles.
						Open-source, local-first, yours to extend.
					</p>

					<!-- On-ramp 1 (the app): OS-detected download button + the full
					     platform matrix. Picks the right build for the visitor and
					     keeps every build one tap away. -->
					<Downloads github={GITHUB} />

					<!-- On-ramp 1, scripted alternative: the one-liner (kept). -->
					<p class="sk-body sk-hero__onramp-lead">
						<strong>Prefer the terminal?</strong> One line installs the app on
						macOS, Linux, and Windows:
					</p>

					<InstallBlock cmd={INSTALL}>
						<p class="sk-install__note">
							Auto-detects your platform. On Linux it pulls the
							<strong>~17&nbsp;MB</strong> <code>.deb</code> when <code>dpkg</code> is
							present (or a <strong>~101&nbsp;MB</strong> AppImage, no sudo); on
							Windows, <code>winget install Ikenga.Shell</code> also works.
						</p>
					</InstallBlock>

					<!-- Skills on-ramp — inline .sk-install so the InstallBlock copy
					     script binds it automatically; own id (#install is taken,
					     and deep-linked from 10+ other pages). -->
					<div class="sk-install" id="skills">
						<div class="sk-install__cmd">
							<code class="sk-install__code">{SKILL}</code>
							<button type="button" class="sk-install__copy" aria-label="Copy skill install command"
								>Copy</button
							>
						</div>
						<p class="sk-install__note">
							<strong>Or skip the app.</strong> Add a skill to plain Claude Code
							anywhere — <code>groundwork</code> and
							<code>ikenga-artifact-builder</code> work with or without Ikenga.
							More skills are coming.
						</p>
					</div>

					<div class="sk-hero__proof">
						<ProofList
							items={[
								'Apache-2.0',
								'Local-first',
								'No account required',
								'Claude-first · Gemini & Codex too',
							]}
						/>
					</div>

					<!-- TODO(WP-26): swap for the real-work composite — file tree + live
					     Claude/Gemini CLIs in split panes + the groundwork board, cropped
					     to content panes (no side-menu/header chrome). This ngwa-cockpit.png
					     is the RETIRED design render (G-21) kept only so the page renders
					     until the capture lands; update src/alt/caption together. -->
					<figure class="sk-shot sk-hero__shot">
						<img
							src="/assets/shell/ngwa-cockpit.png"
							alt="The Ikenga cockpit — a list of skills, agents and commands with a detail pane, managed across projects from one screen."
							width="1680"
							height="1050"
							loading="eager"
							decoding="async"
						/>
						<figcaption>Ikenga doing real work — your setup, running on your machine.</figcaption>
					</figure>
				</div>
			</section>

			<!-- ─────────── Beat 1 — everything is a package ─────────── -->
			<Beat
				heading="Everything is a package."
				img="/assets/shell/oba-store.png"
				alt="The package manager — install, enable and update packages like apps, with provenance and scope."
				caption="Your package manager. Install, update, and inspect every piece."
			>
				<p class="sk-body">
					The cockpit is just the start. Mini-apps, tool servers, engine
					adapters — every capability docks into your workspace as an
					independently installable package. Add what you need, retire what you don't.
				</p>
				<p class="sk-body">
					Composed from independent packages, managed from one screen, running on your machine.
				</p>
			</Beat>

			<!-- ─────────── Beat 2 — the workspace becomes you ─────────── -->
			<Beat
				heading="The workspace becomes you."
				img="/assets/shell/capability-graph.png"
				alt="The capability graph — a radial map of how agents, skills, commands and MCP servers connect."
				caption="See how everything connects — the capability graph across your setup."
				reverse
			>
				<ul class="sk-list">
					<li>Your config lives on your machine — readable as files, versioned in git.</li>
					<li>Every agent, skill, and command you install is yours to inspect and change.</li>
					<li>The cockpit keeps you in sync across projects — no dotfile archaeology.</li>
					<li>
						<BrandIcon name="claude" /> Claude-first — open to
						<BrandIcon name="gemini" /> Gemini and <BrandIcon name="codex" /> Codex
						when you want them.
					</li>
				</ul>
			</Beat>

			<!-- ─────────── Closing CTA — Welcome to your Obi ─────────── -->
			<section class="sk-section">
				<div class="sk-wrap sk-obi">
					<h2 class="sk-display">Welcome to your Obi.</h2>
					<p class="sk-lede">
						Your home for Claude Code — where the skills you run anywhere and the
						packages you install all live in one place: open-source, local-first,
						and built to be made your own. We built it to run our own company. Now
						it's yours.
					</p>
					<div class="sk-obi__cta">
						<Button href="#downloads" variant="primary">Download Ikenga</Button>
						<Button href={GITHUB} variant="ghost" rel="noopener">
							<BrandIcon name="github" /> Star on GitHub
						</Button>
					</div>
					<p class="sk-obi__proof">Apache-2.0. No account required. Read every line.</p>
					<p class="sk-obi__gloss"><em>Obi</em> — the meeting house; the home of your workspace.</p>
				</div>
			</section>

			<!-- ─────────── Subscribe (WP-29 — live newsletter) ─────────── -->
			<section class="sk-section">
				<form class="sk-wrap subscribe" id="subscribe-form" novalidate>
					<label class="subscribe-label" for="subscribe-email">
						Get the <em>ozi</em> — dispatches when Ikenga ships: releases, new
						packages, and notes from the build.
					</label>
					<div class="subscribe-row">
						<input
							id="subscribe-email"
							name="email"
							type="email"
							inputmode="email"
							autocomplete="email"
							placeholder="you@example.com"
							aria-describedby="subscribe-msg"
							required
						/>
						<button type="submit" id="subscribe-btn">Subscribe</button>
					</div>
					<!-- honeypot: hidden from humans, catches bots -->
					<input
						class="subscribe-hp"
						type="text"
						name="company"
						tabindex="-1"
						autocomplete="off"
						aria-hidden="true"
					/>
					<p class="subscribe-consent">
						Double opt-in — we email you once to confirm. No spam, unsubscribe anytime.
					</p>
					<p class="subscribe-msg" id="subscribe-msg" role="status" aria-live="polite"></p>
				</form>
			</section>
		</main>

		<Footer github={GITHUB} />

		<script>
			// Subscribe form (WP-29) — posts to the Listmonk Pages Function.
			const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
			const emailEl = document.getElementById('subscribe-email') as HTMLInputElement | null;
			const btn = document.getElementById('subscribe-btn') as HTMLButtonElement | null;
			const msg = document.getElementById('subscribe-msg');

			form?.addEventListener('submit', async (e) => {
				e.preventDefault();
				if (!emailEl || !btn || !msg) return;
				const email = emailEl.value.trim();
				const company = (form.elements.namedItem('company') as HTMLInputElement)?.value ?? '';
				if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
					msg.textContent = 'Enter a valid email address.';
					msg.dataset.state = 'error';
					emailEl.setAttribute('aria-invalid', 'true');
					emailEl.focus();
					return;
				}
				emailEl.removeAttribute('aria-invalid');
				btn.disabled = true;
				const original = btn.textContent;
				btn.textContent = 'Subscribing…';
				msg.textContent = '';
				delete msg.dataset.state;
				try {
					const res = await fetch('/api/subscribe', {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({ email, company }),
					});
					const data = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };
					if (res.ok && data.ok) {
						form.reset();
						msg.textContent = 'Almost there — check your inbox to confirm.';
						msg.dataset.state = 'ok';
					} else {
						msg.textContent = data.error ?? 'Could not subscribe right now. Please try again.';
						msg.dataset.state = 'error';
					}
				} catch {
					msg.textContent = 'Network error. Please try again.';
					msg.dataset.state = 'error';
				} finally {
					btn.disabled = false;
					btn.textContent = original;
				}
			});
		</script>

		<style>
			/* Page-specific layout — the kit (.sk-*) carries the visual language;
			   this only positions hero/beat/subscribe for the landing instance. */
			html,
			body {
				margin: 0;
			}
			.sk-hero__proof {
				margin-block: var(--space-6) var(--space-8);
			}
			.sk-hero__shot {
				margin-top: var(--space-4);
			}

			/* subscribe form */
			.subscribe {
				display: block;
			}
			.subscribe-label {
				display: block;
				font-size: 1.0625rem;
				color: var(--site-fg);
				max-width: var(--site-measure-body);
				margin-bottom: var(--space-4);
			}
			.subscribe-label em {
				color: var(--site-accent);
				font-style: italic;
			}
			.subscribe-row {
				display: flex;
				gap: var(--space-3);
				flex-wrap: wrap;
				max-width: 34rem;
			}
			.subscribe-row input {
				flex: 1;
				min-width: 14rem;
				padding: 11px 14px;
				border-radius: var(--radius-md, 6px);
				border: 1px solid var(--site-border);
				background: var(--site-surface);
				color: var(--site-fg);
				font: inherit;
				font-size: 0.9375rem;
			}
			.subscribe-row input:focus-visible {
				outline: 2px solid var(--site-accent);
				outline-offset: 1px;
			}
			.subscribe-row button {
				padding: 11px 20px;
				border-radius: var(--radius-md, 6px);
				border: 1px solid transparent;
				background: var(--site-accent);
				color: hsl(28, 30%, 8%);
				font: inherit;
				font-weight: 600;
				font-size: 0.9375rem;
				cursor: pointer;
				transition: filter 0.15s ease;
			}
			.subscribe-row button:hover {
				filter: brightness(1.08);
			}
			.subscribe-row button:focus-visible {
				outline: 2px solid var(--site-accent);
				outline-offset: 2px;
			}
			.subscribe-row button:disabled {
				opacity: 0.6;
				cursor: default;
			}
			.subscribe-hp {
				position: absolute;
				left: -9999px;
				width: 1px;
				height: 1px;
				opacity: 0;
			}
			.subscribe-consent {
				font-size: 0.8125rem;
				color: var(--site-faint);
				margin: var(--space-3) 0 0;
			}
			.subscribe-msg {
				font-size: 0.875rem;
				margin: var(--space-2) 0 0;
				min-height: 1.2em;
			}
			.subscribe-msg[data-state='ok'] {
				color: var(--site-success);
			}
			.subscribe-msg[data-state='error'] {
				color: var(--site-danger);
			}
		</style>
	</body>
</html>
