---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" data-mode="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Ikenga — coming soon</title>
		<meta
			name="description"
			content="Your personal seat of strength for AI-augmented work. Coming soon."
		/>
		<!-- Cloudflare Web Analytics -->
		<script
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon='{"token": "3fdcdf8ab9ba4ca68bd46410d1527108"}'
		></script>
	</head>
	<body>
		<main>
			<div class="mark" aria-hidden="true">I</div>
			<h1>Ikenga</h1>
			<p class="tagline">
				Your personal seat of strength for AI-augmented work.
			</p>

			<p class="welcome">Welcome to your Obi.</p>
			<p class="gloss">
				<em>Obi</em> — the meeting house; the home of your workspace.
			</p>

			<p class="status">Coming soon</p>

			<form class="subscribe" id="subscribe-form" novalidate>
				<label class="subscribe-label" for="subscribe-email">
					Get the <em>ozi</em> — dispatches when Ikenga ships:
					releases, new packages, and notes from the build.
				</label>
				<div class="subscribe-row">
					<input
						id="subscribe-email"
						name="email"
						type="email"
						inputmode="email"
						autocomplete="email"
						placeholder="you@example.com"
						required
					/>
					<button type="submit" id="subscribe-btn">Subscribe</button>
				</div>
				<!-- honeypot: hidden from humans, catches bots -->
				<input
					class="subscribe-hp"
					type="text"
					name="company"
					tabindex="-1"
					autocomplete="off"
					aria-hidden="true"
				/>
				<p class="subscribe-consent">
					Double opt-in — we email you once to confirm. No spam, unsubscribe anytime.
				</p>
				<p class="subscribe-msg" id="subscribe-msg" role="status" aria-live="polite"></p>
			</form>

			<p class="links">
				<a href="/docs/">Read the docs →</a>
			</p>
		</main>

		<script>
			const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
			const emailEl = document.getElementById('subscribe-email') as HTMLInputElement | null;
			const btn = document.getElementById('subscribe-btn') as HTMLButtonElement | null;
			const msg = document.getElementById('subscribe-msg');

			form?.addEventListener('submit', async (e) => {
				e.preventDefault();
				if (!emailEl || !btn || !msg) return;
				const email = emailEl.value.trim();
				const company = (form.elements.namedItem('company') as HTMLInputElement)?.value ?? '';
				if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
					msg.textContent = 'Enter a valid email address.';
					msg.dataset.state = 'error';
					return;
				}
				btn.disabled = true;
				const original = btn.textContent;
				btn.textContent = 'Subscribing…';
				msg.textContent = '';
				delete msg.dataset.state;
				try {
					const res = await fetch('/api/subscribe', {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({ email, company }),
					});
					const data = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };
					if (res.ok && data.ok) {
						form.reset();
						msg.textContent = 'Almost there — check your inbox to confirm.';
						msg.dataset.state = 'ok';
					} else {
						msg.textContent = data.error ?? 'Could not subscribe right now. Please try again.';
						msg.dataset.state = 'error';
					}
				} catch {
					msg.textContent = 'Network error. Please try again.';
					msg.dataset.state = 'error';
				} finally {
					btn.disabled = false;
					btn.textContent = original;
				}
			});
		</script>

		<footer>
			<p>
				Lore drawn from the <em>Ikenga</em> tradition of the Igbo people
				and from Chinua Achebe's <em>Things Fall Apart</em>. See
				<a href="/docs/">About → Lore</a> for full credits.
			</p>
		</footer>

		<style>
			html,
			body {
				height: 100%;
			}
			body {
				margin: 0;
				font-family: var(--font-sans);
				background: var(--bg-base);
				color: hsl(220, 10%, 92%);
				display: grid;
				grid-template-rows: 1fr auto;
				padding: var(--space-8);
			}
			main {
				max-width: 32rem;
				text-align: center;
				margin: auto;
			}
			.mark {
				display: inline-grid;
				place-items: center;
				width: 64px;
				height: 64px;
				margin: 0 auto var(--space-6);
				border-radius: var(--radius-lg);
				background: var(--ember);
				color: var(--bg-base);
				font-family: var(--font-display);
				font-weight: 700;
				font-size: 32px;
				line-height: 1;
			}
			h1 {
				font-family: var(--font-display);
				font-size: 40px;
				margin: 0 0 var(--space-3);
				letter-spacing: -0.02em;
			}
			.tagline {
				font-size: 16px;
				margin: 0 0 var(--space-8);
				opacity: 0.75;
				line-height: 1.5;
			}
			.welcome {
				font-family: var(--font-display);
				font-size: var(--text-h3);
				margin: 0 0 var(--space-2);
				color: var(--kola-amber-soft);
			}
			.gloss {
				font-size: var(--text-caption);
				opacity: 0.6;
				margin: 0 0 var(--space-6);
				line-height: 1.5;
			}
			.status {
				display: inline-block;
				padding: 4px 10px;
				border-radius: var(--radius-pill);
				background: hsla(42, 78%, 50%, 0.12);
				color: var(--kola-amber);
				font-size: var(--text-caption);
				letter-spacing: 0.04em;
				text-transform: uppercase;
				margin: 0 0 var(--space-6);
			}
			.links a {
				color: var(--ember-soft);
				text-decoration: none;
				border-bottom: 1px solid currentColor;
			}
			.links a:hover {
				color: var(--ember);
			}
			.subscribe {
				max-width: 26rem;
				margin: 0 auto var(--space-6);
				text-align: left;
			}
			.subscribe-label {
				display: block;
				font-size: var(--text-caption);
				opacity: 0.7;
				line-height: 1.5;
				margin: 0 0 var(--space-3);
				text-align: center;
			}
			.subscribe-label em {
				color: var(--kola-amber-soft);
				font-style: italic;
			}
			.subscribe-row {
				display: flex;
				gap: var(--space-2);
			}
			.subscribe-row input {
				flex: 1;
				min-width: 0;
				padding: 10px 12px;
				border-radius: var(--radius-md);
				border: 1px solid var(--border, hsl(220, 10%, 30%));
				background: var(--bg-surface, hsl(220, 14%, 12%));
				color: inherit;
				font: inherit;
				font-size: 15px;
			}
			.subscribe-row input:focus-visible {
				outline: 2px solid var(--ember);
				outline-offset: 1px;
				border-color: var(--ember);
			}
			.subscribe-row button {
				padding: 10px 16px;
				border-radius: var(--radius-md);
				border: 0;
				background: var(--ember);
				color: var(--bg-base);
				font: inherit;
				font-weight: 600;
				cursor: pointer;
				white-space: nowrap;
			}
			.subscribe-row button:hover {
				background: var(--kola-amber, var(--ember));
			}
			.subscribe-row button:disabled {
				opacity: 0.6;
				cursor: default;
			}
			.subscribe-hp {
				position: absolute;
				left: -9999px;
				width: 1px;
				height: 1px;
				opacity: 0;
			}
			.subscribe-consent {
				font-size: var(--text-caption);
				opacity: 0.5;
				line-height: 1.5;
				margin: var(--space-3) 0 0;
				text-align: center;
			}
			.subscribe-msg {
				font-size: var(--text-caption);
				line-height: 1.5;
				margin: var(--space-2) 0 0;
				text-align: center;
				min-height: 1.2em;
			}
			.subscribe-msg[data-state='ok'] {
				color: var(--kola-amber);
			}
			.subscribe-msg[data-state='error'] {
				color: hsl(0, 70%, 70%);
			}
			footer {
				text-align: center;
				font-size: var(--text-caption);
				opacity: 0.45;
				line-height: 1.5;
				max-width: 36rem;
				margin: 0 auto;
				padding-top: var(--space-8);
			}
			footer a {
				color: inherit;
				text-decoration: underline;
				text-underline-offset: 2px;
			}
		</style>
	</body>
</html>
