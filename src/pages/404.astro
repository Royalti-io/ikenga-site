---
import '../styles/global.css';
import Button from '../components/Button.astro';

const GITHUB = 'https://github.com/Royalti-io/ikenga';
---

<!doctype html>
<html lang="en" data-theme="A" data-mode="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="robots" content="noindex" />
		<title>Not found — Ikenga</title>
	</head>
	<body class="sk-page">
		<main class="nf">
			<div>
				<p class="sk-eyebrow">404</p>
				<h1 class="sk-display">This path isn't on the map.</h1>
				<p class="sk-body nf__sub">
					The page you're after has moved or never existed. Head back home, or
					find your way through the docs.
				</p>
				<div class="nf__cta">
					<Button href="/" variant="primary">Back home</Button>
					<Button href="/docs/" variant="ghost">Read the docs</Button>
					<Button href={GITHUB} variant="ghost" rel="noopener">GitHub</Button>
				</div>
			</div>
		</main>

		<style>
			html,
			body {
				height: 100%;
				margin: 0;
			}
			.nf {
				min-height: 100vh;
				display: grid;
				place-items: center;
				padding: var(--space-8);
			}
			.nf > div {
				max-width: 34rem;
			}
			.nf__sub {
				margin-bottom: var(--space-6);
			}
			.nf__cta {
				display: flex;
				gap: var(--space-3);
				flex-wrap: wrap;
			}
		</style>
	</body>
</html>
