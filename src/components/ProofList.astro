---
// ProofList — Display. Inline ◆-marked proof points.
interface Props {
	items: string[];
	label?: string;
	center?: boolean;
}
const { items, label = 'What Ikenga is', center = false } = Astro.props;
---

<ul class="sk-proof" class:list={[{ 'sk-proof--center': center }]} aria-label={label}>
	{items.map((item) => <li>{item}</li>)}
</ul>

<style>
	.sk-proof--center {
		justify-content: center;
	}
</style>
