---
// ClosingCta — Pattern. The "Welcome to your Obi" closing band.
import Button from './Button.astro';
interface Props {
	heading: string;
	installHref?: string;
	github?: string;
	gloss?: string;
}
const {
	heading,
	installHref = '#install',
	github = 'https://github.com/Royalti-io/ikenga',
	gloss,
} = Astro.props;
---

<section class="sk-section">
	<div class="sk-wrap sk-obi">
		<h2 class="sk-display">{heading}</h2>
		<p class="sk-lede"><slot /></p>
		<div class="sk-obi__cta">
			<Button href={installHref} variant="primary">Download Ikenga</Button>
			<Button href={github} variant="ghost" rel="noopener">Star on GitHub</Button>
		</div>
		<p class="sk-obi__proof"><slot name="proof" /></p>
		{gloss && <p class="sk-obi__gloss">{gloss}</p>}
	</div>
</section>

<style>
	.sk-obi__proof {
		font-size: 0.8125rem;
		color: var(--site-muted);
		margin: 0 0 var(--space-3);
	}
</style>
