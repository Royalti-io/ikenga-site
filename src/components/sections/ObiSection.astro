---
// ObiSection — WP-09 fill: the closing dark "Welcome to your Obi" beat that
// earns the download (company-proof story, closing CTA pair, Obi gloss).
//
// Sourcing — every factual claim below is traceable to one of two files:
//
// 1. The "we ran our own company on this for 18 months" claim is paraphrased
//    from `site/src/content/docs/docs/index.mdx`:
//      "The 18 months we spent running a real company on this system is the
//       proof it works, not a feature you have to care about."
//
// 2. The G-21 spine line, the Obi gloss, the CTA pair, and the proof line
//    are verbatim from the CURRENT production closing section
//    (`git show main:src/pages/index.astro`):
//      - "We built it to run our own company. Now it's yours."
//      - "Obi — the meeting house; the home of your workspace."
//      - "Apache-2.0. No account required. Read every line."
//      - Button pair: Download Ikenga (primary) / Star on GitHub (ghost).
//
// Glow discipline (D-01): the kola-amber glow is spent on the hero <em> and
// the primary CTA hover only (see `.sk-display em` in site-kit.css). This
// section's <h2> carries no <em>, so it spends none.
//
// CTA target: #install (WP-08's InstallSection id), matching the hero's own
// ghost-row "Download ↓" link — not the old page's #downloads anchor, which
// this redesign doesn't use.
import Button from '../Button.astro';
import BrandIcon from '../BrandIcon.astro';

export interface Props {
	/** GitHub repo URL for the "Star on GitHub" CTA. */
	github?: string;
}
const { github = 'https://github.com/Royalti-io/ikenga' } = Astro.props;
---

<section class="sk-section" id="obi">
	<div class="sk-wrap sk-obi">
		<h2 class="sk-display">Welcome to your Obi.</h2>
		<p class="sk-lede">
			We didn't build Ikenga to sell it. We ran our own company on it for
			eighteen months first — the same shell, skills, and agents you're about
			to download, doing real day-to-day work. That's the proof it works, not
			a feature you have to take on faith.
		</p>
		<p class="sk-lede">We built it to run our own company. Now it's yours.</p>
		<div class="sk-obi__cta">
			<Button href="#install" variant="primary">Download Ikenga</Button>
			<Button href={github} variant="ghost" rel="noopener">
				<BrandIcon name="github" /> Star on GitHub
			</Button>
		</div>
		<p class="sk-obi__proof">Apache-2.0. No account required. Read every line.</p>
		<p class="sk-obi__gloss"><em>Obi</em> — the meeting house; the home of your workspace.</p>
	</div>
</section>
