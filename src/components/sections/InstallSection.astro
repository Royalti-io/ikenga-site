---
// InstallSection — WP-08 fill (was the WP-05 stub). The point-of-intent
// beat: the OS-detected download button + full platform matrix
// (Downloads.astro, unchanged internals — only the surrounding presentation
// is reworked for the light pole), the scripted install one-liner, and the
// skills on-ramp — followed by the proof list.
//
// Copy accounting (G-21 — re-flowed, never re-positioned): every claim below
// is lifted VERBATIM from the prior production src/pages/index.astro (see
// git history on this branch's parent commit) — the install note, the
// skills note, and the proof-list items are byte-identical to that page.
// Only the surrounding heading/lede is new copy (framed from the D-01
// theatre design doc's parchment "skills" section), and the two on-ramps
// are presented as parallel cards instead of stacked hero blocks.
//
// Anchors: this section keeps id="install" (the hero's "Download ↓" ghost
// link) and an inner id="skills" wrapping the skill on-ramp (the hero's "Or
// start with a skill" ghost link) — both reserved by the WP-05 stub, kept
// live here rather than renamed.
//
// Tone: light (parchment pole, WP-02 data-tone="light") — the hard tonal
// seam between the dark packages teaser above and the dark Obi section below.
import Downloads from '../Downloads.astro';
import InstallBlock from '../InstallBlock.astro';
import ProofList from '../ProofList.astro';

interface Props {
	github?: string;
}
const { github = 'https://github.com/Royalti-io/ikenga' } = Astro.props;

// Verbatim from the prior index.astro.
const INSTALL_CMD = 'curl -fsSL https://ikenga.dev/install.sh | sh';
const SKILL_CMD = 'npx skills add royalti-io/groundwork';
---

<section class="sk-section" data-tone="light" id="install">
	<div class="sk-wrap">
		<p class="sk-eyebrow">Install</p>
		<h2 class="sk-h2">The skills work <em>anywhere.</em></h2>
		<p class="sk-lede">
			Skills, agents, and commands are plain files — that's why they're
			portable across systems. <code>groundwork</code> and
			<code>artifact-builder</code> run in Claude Code today, no shell
			required; Ikenga is Claude-first, with Gemini CLI and Codex supported
			too. Ikenga is where these primitives get a visual home: boards in
			panes, artifacts you can see, a workspace that remembers.
		</p>

		<!-- On-ramp 1 (the app): OS-detected download button + the full
		     platform matrix. Downloads.astro internals unchanged — reuses the
		     same detection script and matrix markup as production. -->
		<Downloads github={github} />

		<div class="install-onramps">
			<!-- On-ramp 1, scripted alternative: the one-liner (verbatim). -->
			<div class="install-card">
				<p class="install-card__label">Install the workspace</p>
				<p class="install-card__sub">macOS · Linux · Windows, one line.</p>
				<InstallBlock cmd={INSTALL_CMD}>
					<p class="sk-install__note">
						Auto-detects your platform. On Linux it pulls the
						<strong>~17&nbsp;MB</strong> <code>.deb</code> when <code>dpkg</code> is
						present (or a <strong>~101&nbsp;MB</strong> AppImage, no sudo); on
						Windows, <code>winget install Ikenga.Shell</code> also works.
					</p>
				</InstallBlock>
			</div>

			<!-- On-ramp 2 (skills): skip the app entirely. Inline .sk-install
			     markup (verbatim from the prior page) so InstallBlock's shared
			     copy-button script — which binds every .sk-install on the page —
			     picks it up automatically without a second component instance. -->
			<div class="install-card" id="skills">
				<p class="install-card__label">Add a skill to Claude Code</p>
				<p class="install-card__sub">Works today, with or without the app.</p>
				<div class="sk-install">
					<div class="sk-install__cmd">
						<code class="sk-install__code">{SKILL_CMD}</code>
						<button type="button" class="sk-install__copy" aria-label="Copy skill install command"
							>Copy</button
						>
					</div>
					<p class="sk-install__note">
						<strong>Or skip the app.</strong> Add a skill to plain Claude Code
						anywhere — <code>groundwork</code> and
						<code>ikenga-artifact-builder</code> work with or without Ikenga.
						More skills are coming.
					</p>
				</div>
			</div>
		</div>

		<div class="install-proof">
			<ProofList
				items={[
					'Apache-2.0',
					'Local-first',
					'No account required',
					'Claude-first · Gemini & Codex too',
				]}
			/>
		</div>
	</div>
</section>

<style>
	.install-onramps {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
		gap: var(--space-5, 20px);
		max-width: 50rem;
		margin-top: var(--space-8, 32px);
	}
	.install-card {
		background: var(--site-surface);
		border: 1px solid var(--site-border);
		border-radius: var(--radius-lg, 10px);
		padding: var(--space-5, 20px);
	}
	.install-card__label {
		font-weight: 600;
		font-size: 0.9375rem;
		color: var(--site-fg);
		margin: 0 0 var(--space-2, 8px);
	}
	.install-card__sub {
		font-size: 0.8125rem;
		color: var(--site-muted);
		margin: 0 0 var(--space-4, 16px);
	}
	.install-card .sk-install {
		max-width: none;
	}
	.install-proof {
		margin-top: var(--space-8, 32px);
	}
</style>
