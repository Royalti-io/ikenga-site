---
/**
 * MomentGraph.astro — "Everything connects" v2 (WP-13, supersedes WP-07's
 * section scope over the shipped SPIKE-07 island).
 *
 * A pinned scrollytelling sequence (DEC-10 / DEC-11), four beats over one
 * sticky stage:
 *   1. Radial capability graph (the shipped island — ports the shell Ngwa
 *      analyzer's Bundle mode: radial edge-bundling + kind-band arcs).
 *   2. Node-select → info board (ports GraphDetailCard from
 *      `shell/.../analyze/graph-view.tsx`): kind chip, scope, description,
 *      Connections count, per-edge rows with →/← direction, rel verbs and the
 *      heuristic `*` marker.
 *   3. Store map (ports StoreMatrix): kind rows × scope columns, presence dots.
 *   4. Flow view (ports ngwa-flow): groundwork's procedural step-sequence.
 *
 * SSG-FIRST (island contract ./CONTRACT.md, hardened by DEC-4):
 *   · The radial layout (d3-hierarchy `cluster` + d3-shape `lineRadial`/
 *     `curveBundle`) and every info card / matrix cell / flow step render as
 *     complete static markup at `astro build` time — ZERO client JS is needed
 *     to read all four states.
 *   · The DEFAULT (no-JS) frame is the STACKED layout: the four visualizers
 *     stack vertically, each fully legible, in reading order. This same stacked
 *     frame is what `prefers-reduced-motion` and mobile (<=720px) render.
 *   · Only when JS runs AND motion is allowed does `moment-graph.ts` set
 *     `data-anim="js"`, which upgrades wide viewports to the pinned sequence.
 *     The 400vh track reserves its height up front → CLS 0. IntersectionObserver
 *     step sentinels drive the active `[data-beat]`; the beat transitions are
 *     compositor-safe `transform`/`opacity` only (WAAPI intro + CSS-transition
 *     beat swaps — no CSS scroll-timeline).
 *
 * A11Y: every node is keyboard-focusable (tabindex/role/aria-label, unchanged
 * from WP-07); focusing or hovering a node traces the radial AND drives the
 * info board, whose selection is announced via a visually-hidden aria-live
 * region. Each beat/slide carries its own caption + label; the matrix is a real
 * <table> with a caption.
 *
 * HONESTY (G-19 / G-21): every node, store row, scope column and flow step
 * traces to the registry-verified cast (./graph-fixture.ts + ./graph-slides.ts
 * → ./cast.json). Presence encodings are labelled "staged demo".
 *
 * TONE (CONTRACT.md, locked at G-MOMENT): the dark app object is
 * tone-INDEPENDENT and never flips; only the outer copy (captions / foot) is
 * tone-aware via `--site-*`. Section ships on the dark pole.
 */
import { cluster, hierarchy, type HierarchyNode } from 'd3-hierarchy';
import { arc as d3arc, curveBundle, lineRadial } from 'd3-shape';
import {
	graphFixture,
	KIND_COLOR,
	KIND_GLYPH,
	KIND_LABEL,
	KIND_ORDER,
	REL_KIND,
	type GraphEdge,
	type GraphKind,
	type GraphNode,
} from './graph-fixture';
import { FLOW_SOURCE, FLOW_STEPS, STORE_SCOPES, featuredNodeId, storeGroups, storeTotals } from './graph-slides';

export interface Props {
	/** Tone pole for the outer copy only (captions/foot) — same contract as
	 * MomentHero; the stage itself is a tone-independent dark app object. */
	tone?: 'dark' | 'light';
}
const { tone = 'dark' } = Astro.props;

// ── build-time radial-bundle layout (ports BundleRenderer's layout memo) ──
const SIZE = 640;
const R = SIZE / 2 - 92;

type BundleDatum = { name: string; kind?: GraphKind; node?: GraphNode; children?: BundleDatum[] };

const groups: BundleDatum[] = KIND_ORDER.map((k) => ({
	name: k,
	kind: k,
	children: graphFixture.nodes.filter((n) => n.kind === k).map((n) => ({ name: n.id, kind: k, node: n })),
})).filter((g) => (g.children?.length ?? 0) > 0);

const root = hierarchy<BundleDatum>({ name: 'root', children: groups }).sort((a, b) =>
	(a.data.node?.label ?? a.data.name).localeCompare(b.data.node?.label ?? b.data.name),
);
cluster<BundleDatum>().size([360, R])(root);
const leaves = root.leaves();
const leafById = new Map<string, HierarchyNode<BundleDatum>>();
for (const l of leaves) if (l.data.node) leafById.set(l.data.node.id, l);

const line = lineRadial<HierarchyNode<BundleDatum>>()
	.curve(curveBundle.beta(0.78))
	.radius((d) => d.y ?? 0)
	.angle((d) => ((d.x ?? 0) * Math.PI) / 180);

const links = graphFixture.edges
	.map((e) => {
		const s = leafById.get(e.source);
		const t = leafById.get(e.target);
		if (!s || !t) return null;
		return { edge: e, d: line(s.path(t)) ?? '' };
	})
	.filter((x): x is { edge: GraphEdge; d: string } => x !== null);

const bandArc = d3arc<{ a0: number; a1: number }>()
	.innerRadius(R + 14)
	.outerRadius(R + 18)
	.startAngle((d) => ((d.a0 - 3) * Math.PI) / 180)
	.endAngle((d) => ((d.a1 + 3) * Math.PI) / 180);

const ARC_LABEL_SOLO_NUDGE_DEG = 6;
const arcs = (root.children ?? []).map((g) => {
	const xs = (g.children ?? []).map((c) => c.x ?? 0).sort((a, b) => a - b);
	const a0 = xs[0] ?? 0;
	const a1 = xs[xs.length - 1] ?? 0;
	const count = xs.length;
	const gap = count > 1 ? (a1 - a0) / (count - 1) : 0;
	const mid =
		count <= 1 ? a0 + ARC_LABEL_SOLO_NUDGE_DEG : count % 2 === 1 ? (a0 + a1) / 2 + gap / 2 : (a0 + a1) / 2;
	return { kind: g.data.kind as GraphKind, a0, a1, mid };
});

function degree(id: string): number {
	return graphFixture.edges.filter((e) => e.source === id || e.target === id).length;
}

const HUB_DEGREE = 3;
function shortLabel(label: string): string {
	return label.replace(/^@ikenga\//, '');
}

// ── Info board (Beat 2) — GraphDetailCard data, pre-rendered per node ─────────
// The mcp hub (featuredNodeId) is the default/static frame; the rest render
// hidden and are revealed by keyboard/pointer focus (moment-graph.ts). This
// keeps the client script tiny (a `hidden` toggle, no template engine) and puts
// every card in the SSG HTML — the honest, no-JS-legible way.
const nodeById = new Map(graphFixture.nodes.map((n) => [n.id, n] as const));
const HOME: Record<GraphKind, string> = {
	skill: 'skill',
	command: 'workspace command',
	mcp: 'workspace',
	engine: 'engine',
	pkg: 'pkg',
};
type Conn = { label: string; rel: GraphEdge['rel']; heuristic: boolean };
const cards = graphFixture.nodes.map((n) => {
	const scopeLine = [n.version ? `v${n.version}` : null, HOME[n.kind]].filter(Boolean).join(' · ');
	const out: Conn[] = graphFixture.edges
		.filter((e) => e.source === n.id)
		.map((e) => ({ label: nodeById.get(e.target)?.label ?? e.target, rel: e.rel, heuristic: e.derivation === 'heuristic' }));
	const inc: Conn[] = graphFixture.edges
		.filter((e) => e.target === n.id)
		.map((e) => ({ label: nodeById.get(e.source)?.label ?? e.source, rel: e.rel, heuristic: e.derivation === 'heuristic' }));
	return { node: n, scopeLine, out, inc, connections: out.length + inc.length };
});

const titleId = 'mg-title';
const descId = 'mg-desc';
// window-chrome breadcrumb — workspace scope · project (both real, from cast)
const wsCrumb = `${STORE_SCOPES[0]?.label ?? 'workspace'} · ${STORE_SCOPES[1]?.label ?? 'project'} — analyze`;
---

<section class="mg" data-moment="graph" data-tone={tone === 'light' ? 'light' : undefined}>
	<div class="mg-copy">
		<h2 class="mg-h2">Everything connects.</h2>
		<p class="mg-sub">
			Skills, commands, MCPs, engines, and installed pkgs — one capability graph,
			radial-bundled the same way the shell renders it. Scroll to walk the wiring.
		</p>
	</div>

	<!-- visually-hidden live region: announces the selected node (a11y) -->
	<span class="mg-live sr-only" aria-live="polite" aria-atomic="true"></span>

	<div class="mg-scrolly">
		<div class="mg-track">
			<!-- pinned-only step sentinels (observed for the active beat) -->
			<div class="mg-steps" aria-hidden="true">
				<div class="mg-step" data-step="1"></div>
				<div class="mg-step" data-step="2"></div>
				<div class="mg-step" data-step="3"></div>
				<div class="mg-step" data-step="4"></div>
			</div>

			<div class="mg-sticky" data-beat="1">
				<div class="mg-progress" aria-hidden="true">
					<i class="on"></i><i></i><i></i><i></i>
				</div>

				<!-- LEFT: the theatre stage (dark app object) holding the 4 layers -->
				<div class="mg-stagecol">
					<div class="mg-frame-bar" aria-hidden="true">
						<i></i><i></i><i></i>
						<span class="bc">{wsCrumb}</span>
					</div>
					<div class="mg-frame-body">
						<!-- BEAT 1+2 : radial graph (resident) -->
						<div class="mg-layer mg-l-radial" aria-label="Beat 1 — capability graph">
							<svg
								class="mg-svg"
								role="img"
								aria-labelledby={`${titleId} ${descId}`}
								viewBox={`0 0 ${SIZE} ${SIZE}`}
								preserveAspectRatio="xMidYMid meet"
							>
								<title id={titleId}>Ikenga capability graph</title>
								<desc id={descId}>
									{`Radial-bundle diagram of ${graphFixture.nodes.length} real, shipping capabilities -- skills, commands, MCPs, engines, and installed pkgs -- grouped into ${arcs.length} kind bands and joined by ${graphFixture.edges.length} links. Every node is keyboard-focusable via Tab; focusing one traces its links (amber outgoing, teal incoming) and opens its detail card.`}
								</desc>
								<g transform={`translate(${SIZE / 2},${SIZE / 2})`}>
									{arcs.map((a) => {
										const rad = ((a.mid - 90) * Math.PI) / 180;
										const lr = R + 30;
										const band = bandArc(a) ?? undefined;
										return (
											<g class="mg-arc">
												{band && <path d={band} fill={KIND_COLOR[a.kind]} opacity={0.55} />}
												<text
													x={Math.cos(rad) * lr}
													y={Math.sin(rad) * lr}
													text-anchor="middle"
													dominant-baseline="middle"
													class="mg-arc-label"
													fill={KIND_COLOR[a.kind]}
												>
													{KIND_LABEL[a.kind].toUpperCase()}
												</text>
											</g>
										);
									})}

									<g fill="none">
										{links.map(({ edge, d }) => (
											<path
												class="mg-edge"
												d={d}
												data-source={edge.source}
												data-target={edge.target}
												stroke={KIND_COLOR[REL_KIND[edge.rel]]}
												stroke-width="1.1"
												stroke-dasharray={edge.derivation === 'heuristic' ? '4,4' : undefined}
											/>
										))}
									</g>

									{leaves.map((leaf) => {
										const n = leaf.data.node;
										if (!n) return null;
										const angle = leaf.x ?? 0;
										const flip = angle >= 180;
										const deg = degree(n.id);
										const r = 4 + Math.min(5, deg * 0.8);
										return (
											<g
												class="mg-node"
												data-node-id={n.id}
												data-kind={n.kind}
												data-hub={deg >= HUB_DEGREE ? '' : undefined}
												tabindex="0"
												role="button"
												aria-label={`${n.label} — ${KIND_LABEL[n.kind]}, ${deg} connection${deg === 1 ? '' : 's'}. ${n.detail}`}
												transform={`rotate(${angle - 90}) translate(${leaf.y ?? 0},0)`}
											>
												<circle
													r={r}
													style={`--mg-node-r: ${r}px`}
													fill={`color-mix(in srgb, ${KIND_COLOR[n.kind]} 24%, var(--moment-shell-bg, hsl(28, 22%, 2.5%)))`}
													stroke={KIND_COLOR[n.kind]}
													stroke-width="1.5"
												/>
												<text
													class="mg-node-label"
													dy="0.31em"
													x={flip ? -(r + 5) : r + 5}
													text-anchor={flip ? 'end' : 'start'}
													transform={flip ? 'rotate(180)' : undefined}
												>
													{shortLabel(n.label)}
												</text>
											</g>
										);
									})}
								</g>
							</svg>
						</div>

						<!-- BEAT 2 : node-select → info board (GraphDetailCard anatomy) -->
						<div class="mg-layer mg-l-info" data-featured={featuredNodeId} aria-label="Beat 2 — selected node detail">
							{cards.map(({ node: n, scopeLine, out, inc, connections }) => (
								<div class="mg-gd" data-node={n.id} hidden={n.id !== featuredNodeId}>
									<span class="mg-gd-kind" style={`--accent: var(--nk-${n.kind})`}>
										<span class="dd"></span>{n.kind}
									</span>
									<div class="mg-gd-name">{n.label}</div>
									<div class="mg-gd-scope">{scopeLine}</div>
									{n.description && <div class="mg-gd-desc">{n.description}</div>}
									<div class="mg-gd-ch"><span>Connections</span><span>{connections}</span></div>
									{out.map((c) => (
										<div class="mg-gd-conn">
											<span class="ar out">→</span>
											<span class="tg">{c.label}</span>
											<span class="rl">{c.rel}{c.heuristic ? '*' : ''}</span>
										</div>
									))}
									{inc.map((c) => (
										<div class="mg-gd-conn">
											<span class="ar in">←</span>
											<span class="tg">{c.label}</span>
											<span class="rl">{c.rel}{c.heuristic ? '*' : ''}</span>
										</div>
									))}
								</div>
							))}
						</div>

						<!-- BEAT 3 : store map (StoreMatrix anatomy) -->
						<div class="mg-layer mg-l-store" aria-label="Beat 3 — store map">
							<div class="mg-sm">
								<div class="mg-sm-toolbar">
									<span class="mg-sm-title"><span class="g">▦</span> Store map</span>
									<span class="mg-sm-meta">{storeTotals.rows} entries · {storeTotals.scopes} scopes</span>
									<span class="mg-sm-spacer"></span>
									<span class="mg-sm-search" aria-hidden="true">filter entries…</span>
								</div>
								<div class="mg-sm-stage">
									<table class="mg-mx">
										<caption class="sr-only">
											{`Ọba presence matrix — ${storeTotals.rows} registry entries across ${storeTotals.scopes} scopes. Staged demo: presence (enabled / local / absent) illustrates the encoding.`}
										</caption>
										<thead>
											<tr>
												<th class="mg-mx-corner" scope="col">Ọba entry ↓ / scope →</th>
												{STORE_SCOPES.map((s) => (
													<th class="mg-mx-colh" scope="col"><span class="mg-mx-colnm">{s.label}</span></th>
												))}
											</tr>
										</thead>
										<tbody>
											{storeGroups.map((g) => (
												<>
													<tr class="mg-mx-kindrow">
														<td colspan={STORE_SCOPES.length + 1}>
															<span class="mg-mx-kindlbl">
																<span class="kd" style={`background: var(--nk-${g.kind})`}></span>{g.label}
																<span class="ct">{g.rows.length}</span>
															</span>
														</td>
													</tr>
													{g.rows.map((r) => (
														<tr>
															<th class="mg-mx-rowh" scope="row">
																<span class="mg-mx-rowcard">
																	<span class="mg-mx-ic" style={`color: var(--nk-${g.kind})`}>{KIND_GLYPH[g.kind]}</span>
																	<span class="mg-mx-nm">{r.label}</span>
																	<span class={`mg-mx-st ${r.status}`}>{r.status}</span>
																</span>
															</th>
															{r.cells.map((c, i) => (
																<td class="mg-mx-cell">
																	<span
																		class={`mg-mx-dot ${c === 'enabled' ? 'on' : c}`}
																		title={`${STORE_SCOPES[i].label}: ${c === 'none' ? 'absent' : c}`}
																	>
																		<span class="mark"></span>
																	</span>
																</td>
															))}
														</tr>
													))}
												</>
											))}
										</tbody>
									</table>
								</div>
								<div class="mg-sm-foot">
									<span><b>{storeTotals.rows}</b> entries × <b>{storeTotals.scopes}</b> scopes</span>
									<span class="sep">|</span>
									<span style="color:var(--st-enabled)"><b>staged demo</b></span>
									<span class="sep">|</span>
									<span>presence dots illustrate the matrix encoding</span>
								</div>
							</div>
						</div>

						<!-- BEAT 4 : flow view (ngwa-flow anatomy) -->
						<div class="mg-layer mg-l-flow" aria-label="Beat 4 — orchestration flow">
							<div class="mg-fl">
								<div class="mg-fl-toolbar">
									<span class="mg-fl-title"><span class="g">⛓</span> Orchestration flow</span>
									<span class="mg-fl-meta">1 flowable</span>
									<span class="mg-fl-badge">regex-derived</span>
								</div>
								<div class="mg-fl-body">
									<p class="mg-fl-note">
										<b>How this is built:</b> the capability graph reads <i>declarative</i> wiring from
										frontmatter. This <i>procedural</i> sequence is parsed from the body — a lightweight
										regex pass, not an LLM read. Best-effort trace.
									</p>
									<div class="mg-fl-source">
										<span class="g" style={`color: var(--nk-${FLOW_SOURCE.kind})`}>{KIND_GLYPH[FLOW_SOURCE.kind]}</span>
										<b>{FLOW_SOURCE.label}</b><span class="meta">{FLOW_SOURCE.meta}</span>
									</div>
									<div class="mg-fl-chain">
										{FLOW_STEPS.map((st, i) => (
											<div>
												<div class="mg-fl-step">
													<div class="mg-fl-num">{st.n}</div>
													<div class="mg-fl-stepbody">
														<div class="mg-fl-label">{st.label}</div>
														{st.refs.length > 0 && (
															<div class="mg-fl-refs">
																{st.refs.map((rf) => (
																	<span class="mg-fl-ref" style={`border-left-color: var(--nk-${rf.kind})`}>
																		<span class="g" style={`color: var(--nk-${rf.kind})`}>{KIND_GLYPH[rf.kind]}</span>
																		{rf.name}<span class="rk">{rf.kind}</span>
																	</span>
																))}
															</div>
														)}
													</div>
												</div>
												{i < FLOW_STEPS.length - 1 && <div class="mg-fl-conn"></div>}
											</div>
										))}
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- RIGHT: scrolling narrative caption (content swaps per beat) -->
				<div class="mg-caption">
					<div class="mg-cap" data-for="1">
						<div class="mg-cap-kick">Beat 1 · Radial graph</div>
						<h3>One capability graph.</h3>
						<p>Skills, commands, MCPs, engines, and installed pkgs — radial-bundled exactly the way the shell's Ngwa analyzer renders them.</p>
						<p class="foot"><span class="hd">◆</span> Staged demo — every node is a real, shipping capability.</p>
					</div>
					<div class="mg-cap" data-for="2">
						<div class="mg-cap-kick">Beat 2 · Select a node</div>
						<h3>Click one, read the wiring.</h3>
						<p>The info board is the shell's own detail card — kind chip, scope, description, then every connection with its relation verb. <code>*</code> marks a heuristic (inferred) edge.</p>
						<p class="foot"><span class="hd">→</span> outgoing · <span class="hd hd-in">←</span> incoming · dashed = heuristic</p>
					</div>
					<div class="mg-cap" data-for="3">
						<div class="mg-cap-kick">Beat 3 · Store map</div>
						<h3>The breadth, at a glance.</h3>
						<p>Every store-backed primitive × the scopes it lives in. One matrix shows how far the workspace reaches — enabled, local, or absent per scope.</p>
						<p class="foot"><span class="hd">▦</span> Presence matrix — the shell's Ọba store map.</p>
					</div>
					<div class="mg-cap" data-for="4">
						<div class="mg-cap-kick">Beat 4 · Flow view</div>
						<h3>How the work moves.</h3>
						<p>Declarative wiring is only half the story. The flow view traces the <i>procedural</i> step-sequence inside a skill — numbered steps and the capabilities each one calls.</p>
						<p class="foot"><span class="hd">⛓</span> Orchestration flow — parsed, best-effort.</p>
					</div>
				</div>
			</div>
		</div>
	</div>

	<p class="mg-foot">
		<span class="mg-hd" aria-hidden="true">◆</span> Staged demo — every node, store row and flow step is a real, shipping
		capability · hover or tab through a node to trace its links and open its card
	</p>
</section>

<script is:inline>
	/* Parse-time layout upgrade (WP-13 verify fix): set data-anim="js" BEFORE
	   the section first paints, so the 400vh pinned track is reserved from the
	   start and the DOMContentLoaded module never causes a layout jump. Runs
	   per instance; no-JS and reduced-motion readers never get the pin. */
	(() => {
		const s = document.currentScript;
		const el = s && s.previousElementSibling;
		if (
			el &&
			el.matches('[data-moment="graph"]') &&
			!matchMedia('(prefers-reduced-motion: reduce)').matches
		) {
			el.dataset.anim = 'js';
		}
		if (s) s.remove();
	})();
</script>

<style>
	/* ── "Everything connects" v2 (WP-13) ────────────────────────────────────
	   The dark app OBJECT internals are tone-INDEPENDENT `--moment-*` tokens
	   (CONTRACT.md); the outer copy is tone-aware via `--site-*`. `--nk-*`
	   (kind hues) and `--st-*` (store presence) mirror the shell's own tokens —
	   there is no site-tier equivalent, so they live here as component locals,
	   same pattern as `--moment-*`. */
	.mg {
		--mg-ease: cubic-bezier(0.22, 0.61, 0.16, 1);

		--moment-shell-bg: hsl(28, 22%, 2.5%);
		--moment-surface: hsl(28, 14%, 7%);
		--moment-raised: hsl(28, 11%, 11%);
		--moment-sunken: hsl(28, 24%, 1.8%);
		--moment-shell-border: hsl(30 18% 18% / 0.9);
		--moment-border-soft: hsl(28, 14%, 11%);
		--moment-border-strong: hsl(28, 14%, 30%);
		--moment-fg: hsl(36, 28%, 90%);
		--moment-muted: hsl(32, 11%, 56%);
		/* 53% (was 44%): 4.5:1+ on the darkest app-object panels — WP-15 a11y gate
		   (LH flagged 19 micro-labels at 3.83–4.14 with the 44% value). */
		--moment-faint: hsl(28, 10%, 53%);
		--moment-node-label: hsl(32, 11%, 62%);
		--moment-node-label-hot: hsl(36, 28%, 92%);
		--moment-accent: hsl(42, 78%, 54%);
		--moment-success: hsl(170, 42%, 54%);

		--nk-skill: hsl(42, 84%, 60%);
		--nk-command: hsl(20, 64%, 54%);
		--nk-mcp: hsl(170, 44%, 52%);
		--nk-engine: hsl(284, 48%, 64%);
		--nk-pkg: hsl(212, 48%, 60%);

		--st-enabled: hsl(170, 42%, 54%);
		--st-local: hsl(42, 78%, 54%);
		--st-orphaned: hsl(8, 68%, 55%);

		display: block;
		padding-block: var(--space-8, 32px);
		background: var(--site-bg);
		color: var(--site-fg);
		font-family: var(--site-font-body);
	}

	.sr-only {
		position: absolute !important;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.mg-copy {
		text-align: center;
		max-width: 60rem;
		margin: 0 auto var(--space-6, 24px);
		padding-inline: var(--space-6, 24px);
	}
	.mg-h2 {
		font-family: var(--site-font-display);
		font-weight: 600;
		font-size: clamp(1.6rem, 3.6vw, 2.4rem);
		line-height: 1.12;
		letter-spacing: -0.01em;
		margin: 0 0 var(--space-3, 12px);
	}
	.mg-sub {
		font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
		color: var(--site-muted);
		max-width: 48ch;
		margin: 0 auto;
		line-height: 1.5;
	}

	/* ════════════ STACKED (default = no-JS / reduced-motion / mobile) ════════
	   The four layers stack vertically as framed blocks, interleaved with their
	   captions in reading order. This is the complete, legible, zero-JS frame. */
	.mg-scrolly {
		position: relative;
	}
	.mg-track {
		position: relative;
	}
	.mg-steps {
		display: none;
	}
	.mg-progress {
		display: none;
	}
	.mg-sticky {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-5, 20px);
		max-width: 46rem;
		margin-inline: auto;
		padding-inline: var(--space-6, 24px);
	}
	/* stagecol + caption dissolve so their children interleave as grid items */
	.mg-stagecol,
	.mg-frame-body,
	.mg-caption {
		display: contents;
	}
	.mg-frame-bar {
		display: none;
	}

	/* each layer = a self-contained framed app panel in the stacked frame */
	.mg-layer {
		position: relative;
		background: var(--moment-shell-bg);
		border: 1px solid var(--moment-shell-border);
		border-radius: var(--radius-lg, 10px);
		box-shadow: 0 24px 60px -28px hsl(0 0% 0% / 0.7);
		overflow: hidden;
	}
	.mg-l-radial {
		display: grid;
		place-items: center;
		padding: var(--space-4, 16px);
	}
	.mg-l-info {
		padding: var(--space-5, 20px);
	}

	/* interleave order: cap1, radial, cap2, info, cap3, store, cap4, flow */
	.mg-cap[data-for='1'] { order: 1; }
	.mg-l-radial { order: 2; }
	.mg-cap[data-for='2'] { order: 3; }
	.mg-l-info { order: 4; }
	.mg-cap[data-for='3'] { order: 5; }
	.mg-l-store { order: 6; }
	.mg-cap[data-for='4'] { order: 7; }
	.mg-l-flow { order: 8; }

	.mg-cap {
		max-width: 52ch;
	}
	.mg-cap-kick {
		font-family: var(--site-font-mono);
		font-size: 10px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--site-accent);
		margin-bottom: var(--space-2, 8px);
	}
	.mg-cap h3 {
		font-family: var(--site-font-display);
		font-weight: 600;
		font-size: clamp(1.3rem, 3vw, 1.9rem);
		line-height: 1.14;
		letter-spacing: -0.01em;
		margin: 0 0 var(--space-2, 8px);
	}
	.mg-cap p {
		color: var(--site-muted);
		max-width: 42ch;
		margin: 0;
		font-size: 0.9375rem;
		line-height: 1.5;
	}
	.mg-cap code {
		font-family: var(--site-font-mono);
		font-size: 0.82em;
		color: var(--site-accent);
	}
	.mg-cap .foot {
		margin-top: var(--space-3, 12px);
		font-size: 0.78rem;
		color: var(--site-faint);
		font-family: var(--site-font-mono);
		letter-spacing: 0.02em;
	}
	.mg-cap .foot .hd {
		color: var(--site-accent);
	}
	.mg-cap .foot .hd-in {
		color: var(--site-success);
	}

	/* ── radial SVG ─────────────────────────────────────────────────────────── */
	.mg-svg {
		display: block;
		width: 100%;
		max-width: 30rem;
		aspect-ratio: 1 / 1;
	}
	.mg-arc-label {
		font: 500 8.5px var(--site-font-mono);
		letter-spacing: 0.16em;
	}
	.mg-edge {
		stroke-opacity: 0.28;
		transition: stroke-opacity 0.2s var(--mg-ease);
	}
	.mg-svg.mg-tracing .mg-edge {
		stroke-opacity: 0.06;
	}
	.mg-edge.mg-edge-out {
		stroke: var(--moment-accent);
		stroke-width: 2;
		stroke-opacity: 0.9;
	}
	.mg-edge.mg-edge-in {
		stroke: var(--moment-success);
		stroke-width: 2;
		stroke-opacity: 0.9;
	}
	.mg-edge.mg-edge-dim {
		stroke-opacity: 0.04;
	}
	.mg-node {
		cursor: pointer;
	}
	.mg-node circle {
		transition: stroke-width 0.15s var(--mg-ease);
	}
	.mg-node-label {
		font: 500 8px var(--site-font-mono);
		fill: var(--moment-node-label);
		transition: fill 0.15s var(--mg-ease);
	}
	.mg-node.mg-node-hot circle {
		stroke-width: 2.5;
	}
	.mg-node.mg-node-hot .mg-node-label {
		fill: var(--moment-node-label-hot);
		font-weight: 600;
	}
	.mg-node.mg-node-dim {
		opacity: 0.18;
	}
	.mg-node:focus-visible circle {
		outline: 2px solid var(--moment-accent);
		outline-offset: 2px;
	}

	/* ── info board (GraphDetailCard) ───────────────────────────────────────── */
	.mg-gd {
		width: 100%;
		max-width: 17rem;
		margin-inline: auto;
		background: color-mix(in srgb, var(--moment-surface) 88%, transparent);
		border: 1px solid var(--moment-shell-border);
		border-radius: var(--radius-lg, 10px);
		box-shadow: 0 24px 60px -24px hsl(0 0% 0% / 0.7);
		padding: 15px;
	}
	.mg-gd[hidden] {
		display: none;
	}
	.mg-gd-kind {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--site-font-mono);
		font-size: 9.5px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 3px 9px;
		border-radius: var(--radius-pill, 999px);
		margin-bottom: 9px;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 16%, var(--moment-raised));
	}
	.mg-gd-kind .dd {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
	}
	.mg-gd-name {
		font-size: 16px;
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.1;
		color: var(--moment-fg);
	}
	.mg-gd-scope {
		font-family: var(--site-font-mono);
		font-size: 10px;
		color: var(--moment-faint);
		margin-top: 4px;
	}
	.mg-gd-desc {
		font-size: 12px;
		color: var(--moment-muted);
		line-height: 1.5;
		margin: 10px 0;
		padding: 10px 0;
		border-top: 1px solid var(--moment-border-soft);
		border-bottom: 1px solid var(--moment-border-soft);
	}
	.mg-gd-ch {
		display: flex;
		justify-content: space-between;
		font-family: var(--site-font-mono);
		font-size: 9px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--moment-faint);
		margin: 8px 0 6px;
	}
	.mg-gd-conn {
		display: flex;
		align-items: center;
		gap: 9px;
		padding: 4px 0;
		font-size: 12px;
	}
	.mg-gd-conn .ar {
		font-family: var(--site-font-mono);
		font-size: 11px;
		width: 14px;
		text-align: center;
	}
	.mg-gd-conn .ar.out {
		color: var(--moment-accent);
	}
	.mg-gd-conn .ar.in {
		color: var(--moment-success);
	}
	.mg-gd-conn .tg {
		color: var(--moment-muted);
	}
	.mg-gd-conn .rl {
		margin-left: auto;
		font-family: var(--site-font-mono);
		font-size: 9px;
		color: var(--moment-faint);
	}

	/* ── store map (StoreMatrix) ────────────────────────────────────────────── */
	.mg-sm {
		display: flex;
		flex-direction: column;
		width: 100%;
	}
	.mg-sm-toolbar {
		display: flex;
		align-items: center;
		gap: var(--space-3, 12px);
		padding: 8px var(--space-4, 16px);
		border-bottom: 1px solid var(--moment-border-soft);
		background: var(--moment-shell-bg);
	}
	.mg-sm-title {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		font-size: 12px;
		color: var(--moment-fg);
	}
	.mg-sm-title .g {
		color: var(--moment-muted);
	}
	.mg-sm-meta {
		font-family: var(--site-font-mono);
		font-size: 10px;
		color: var(--moment-faint);
	}
	.mg-sm-spacer {
		flex: 1;
	}
	.mg-sm-search {
		font-family: var(--site-font-mono);
		font-size: 10px;
		color: var(--moment-muted);
		background: var(--moment-sunken);
		border: 1px solid var(--moment-border-soft);
		border-radius: var(--radius-sm, 4px);
		padding: 4px 9px;
	}
	/* the matrix keeps its OWN horizontal scroller → body never scrolls sideways */
	.mg-sm-stage {
		overflow-x: auto;
		background: var(--moment-shell-bg);
		padding: var(--space-3, 12px);
	}
	.mg-mx {
		border-collapse: separate;
		border-spacing: 0;
		width: 100%;
	}
	.mg-mx th,
	.mg-mx td {
		text-align: left;
	}
	.mg-mx-corner {
		font-family: var(--site-font-mono);
		font-size: 8.5px;
		color: var(--moment-faint);
		letter-spacing: 0.04em;
		padding: 4px 8px;
		white-space: nowrap;
		font-weight: 400;
	}
	.mg-mx-colh {
		padding: 4px 6px;
	}
	.mg-mx-colnm {
		display: inline-block;
		font-family: var(--site-font-mono);
		font-size: 9.5px;
		color: var(--moment-muted);
		writing-mode: vertical-rl;
		transform: rotate(180deg);
		white-space: nowrap;
		font-weight: 400;
	}
	.mg-mx-kindrow td {
		padding: 8px 8px 3px;
	}
	.mg-mx-kindlbl {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--site-font-mono);
		font-size: 9px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--moment-faint);
	}
	.mg-mx-kindlbl .kd {
		width: 7px;
		height: 7px;
		border-radius: 50%;
	}
	.mg-mx-kindlbl .ct {
		color: var(--moment-faint);
		opacity: 0.7;
	}
	.mg-mx-rowh {
		padding: 3px 8px;
		font-weight: 400;
	}
	.mg-mx-rowcard {
		display: inline-flex;
		align-items: center;
		gap: 7px;
	}
	.mg-mx-ic {
		font-size: 11px;
	}
	.mg-mx-nm {
		font-size: 11px;
		color: var(--moment-fg);
	}
	.mg-mx-st {
		font-family: var(--site-font-mono);
		font-size: 8px;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		padding: 1px 6px;
		border-radius: var(--radius-pill, 999px);
	}
	.mg-mx-st.enabled {
		background: color-mix(in srgb, var(--st-enabled) 18%, var(--moment-raised));
		color: var(--st-enabled);
	}
	.mg-mx-st.local {
		background: color-mix(in srgb, var(--st-local) 18%, var(--moment-raised));
		color: var(--st-local);
	}
	.mg-mx-cell {
		text-align: center;
		padding: 3px 6px;
	}
	.mg-mx-dot {
		display: inline-grid;
		place-items: center;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		border: 1px solid transparent;
	}
	.mg-mx-dot .mark {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: transparent;
	}
	.mg-mx-dot.on {
		background: color-mix(in srgb, var(--st-enabled) 16%, transparent);
		border-color: color-mix(in srgb, var(--st-enabled) 32%, transparent);
	}
	.mg-mx-dot.on .mark {
		background: var(--st-enabled);
		box-shadow: 0 0 10px color-mix(in srgb, var(--st-enabled) 70%, transparent);
	}
	.mg-mx-dot.local {
		background: color-mix(in srgb, var(--st-local) 16%, transparent);
		border-color: color-mix(in srgb, var(--st-local) 32%, transparent);
	}
	.mg-mx-dot.local .mark {
		background: var(--st-local);
		box-shadow: 0 0 10px color-mix(in srgb, var(--st-local) 60%, transparent);
	}
	.mg-mx-dot.none .mark {
		background: hsl(28 10% 22%);
	}
	.mg-sm-foot {
		display: flex;
		gap: var(--space-3, 12px);
		align-items: center;
		flex-wrap: wrap;
		padding: 7px var(--space-4, 16px);
		border-top: 1px solid var(--moment-border-soft);
		font-family: var(--site-font-mono);
		font-size: 9.5px;
		color: var(--moment-muted);
		background: var(--moment-shell-bg);
	}
	.mg-sm-foot .sep {
		color: var(--moment-border-strong);
	}
	.mg-sm-foot b {
		color: var(--moment-fg);
	}

	/* ── flow view (ngwa-flow) ──────────────────────────────────────────────── */
	.mg-fl {
		display: flex;
		flex-direction: column;
		width: 100%;
	}
	.mg-fl-toolbar {
		display: flex;
		align-items: center;
		gap: var(--space-3, 12px);
		padding: 8px var(--space-4, 16px);
		border-bottom: 1px solid var(--moment-border-soft);
		background: var(--moment-shell-bg);
	}
	.mg-fl-title {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		font-size: 12px;
		color: var(--moment-fg);
	}
	.mg-fl-title .g {
		color: var(--moment-muted);
	}
	.mg-fl-meta {
		font-family: var(--site-font-mono);
		font-size: 10px;
		color: var(--moment-faint);
	}
	.mg-fl-badge {
		font-family: var(--site-font-mono);
		font-size: 9px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--st-local);
		background: color-mix(in srgb, var(--st-local) 12%, transparent);
		border: 1px solid color-mix(in srgb, var(--st-local) 35%, transparent);
		padding: 2px 7px;
		border-radius: var(--radius-pill, 999px);
	}
	.mg-fl-body {
		background: var(--moment-shell-bg);
		padding: var(--space-4, 16px) var(--space-5, 20px);
	}
	.mg-fl-note {
		font-family: var(--site-font-mono);
		font-size: 10px;
		color: var(--moment-muted);
		line-height: 1.6;
		margin: 0 0 var(--space-5, 20px);
		padding: var(--space-3, 12px) var(--space-4, 16px);
		background: var(--moment-surface);
		border: 1px solid var(--moment-border-soft);
		border-left: 2px solid var(--st-local);
		border-radius: var(--radius-xs, 3px);
	}
	.mg-fl-note b {
		color: var(--moment-fg);
		font-family: var(--site-font-body);
	}
	.mg-fl-source {
		display: flex;
		align-items: baseline;
		gap: var(--space-2, 8px);
		margin-bottom: var(--space-4, 16px);
		font-size: 14px;
		color: var(--moment-fg);
	}
	.mg-fl-source b {
		font-family: var(--site-font-body);
	}
	.mg-fl-source .meta {
		font-family: var(--site-font-mono);
		font-size: 10px;
		color: var(--moment-faint);
	}
	.mg-fl-chain {
		display: flex;
		flex-direction: column;
	}
	.mg-fl-step {
		display: flex;
		gap: var(--space-3, 12px);
		align-items: flex-start;
	}
	.mg-fl-num {
		flex-shrink: 0;
		width: 24px;
		height: 24px;
		border-radius: 50%;
		background: var(--moment-raised);
		border: 1px solid var(--moment-border-strong);
		color: var(--moment-muted);
		font-family: var(--site-font-mono);
		font-size: 11px;
		font-weight: 600;
		display: grid;
		place-items: center;
		font-variant-numeric: tabular-nums;
	}
	.mg-fl-stepbody {
		flex: 1;
		min-width: 0;
		padding-bottom: var(--space-2, 8px);
	}
	.mg-fl-label {
		font-size: 13px;
		color: var(--moment-fg);
		line-height: 1.45;
	}
	.mg-fl-refs {
		display: flex;
		flex-wrap: wrap;
		gap: 5px;
		margin-top: 6px;
	}
	.mg-fl-ref {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 2px 7px 2px 6px;
		background: var(--moment-surface);
		border: 1px solid var(--moment-border-soft);
		border-left: 2px solid var(--moment-border-strong);
		border-radius: var(--radius-xs, 3px);
		font-size: 11px;
		color: var(--moment-fg);
	}
	.mg-fl-ref .rk {
		font-family: var(--site-font-mono);
		font-size: 8.5px;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--moment-faint);
	}
	.mg-fl-conn {
		width: 2px;
		height: 14px;
		margin-left: 11px;
		background: var(--moment-border-soft);
	}

	.mg-foot {
		text-align: center;
		margin-top: var(--space-6, 24px);
		font-size: 0.8125rem;
		color: var(--site-faint);
		padding-inline: var(--space-6, 24px);
	}
	.mg-hd {
		color: var(--site-accent);
	}

	/* ════════════ PINNED (JS + motion-allowed + wide) ═══════════════════════
	   The parse-time inline script above sets [data-anim="js"] only when motion
	   is allowed — BEFORE first paint, so the 400vh track is reserved from the
	   start (no layout jump; CLS 0). Reduced-motion and no-JS never reach this
	   block (stay stacked, zero animation). */
	@media (min-width: 721px) {
		.mg[data-anim='js'] .mg-track {
			height: 400vh;
		}
		.mg[data-anim='js'] .mg-steps {
			display: block;
			position: absolute;
			inset: 0;
			z-index: 0;
		}
		.mg[data-anim='js'] .mg-step {
			height: 25%;
		}
		.mg[data-anim='js'] .mg-sticky {
			position: sticky;
			top: 0;
			height: 100vh;
			grid-template-columns: 1fr minmax(300px, 440px);
			align-items: center;
			gap: var(--space-8, 32px);
			max-width: 74rem;
			padding-inline: var(--space-6, 24px);
			z-index: 2;
			pointer-events: none;
		}
		/* the app object frame is the stagecol; children are absolute overlays */
		.mg[data-anim='js'] .mg-stagecol {
			display: block;
			position: relative;
			height: min(78vh, 560px);
			background: var(--moment-shell-bg);
			border: 1px solid var(--moment-shell-border);
			border-radius: var(--radius-lg, 10px);
			box-shadow:
				0 32px 80px -28px hsl(0 0% 0% / 0.82),
				inset 0 1px 0 hsl(40 40% 60% / 0.06);
			overflow: hidden;
		}
		.mg[data-anim='js'] .mg-frame-bar {
			display: flex;
			align-items: center;
			gap: 7px;
			height: 30px;
			padding: 0 12px;
			border-bottom: 1px solid var(--moment-border-soft);
			background: var(--moment-sunken);
		}
		.mg[data-anim='js'] .mg-frame-bar i {
			width: 8px;
			height: 8px;
			border-radius: 50%;
			background: hsl(28 12% 20%);
		}
		.mg[data-anim='js'] .mg-frame-bar .bc {
			margin-left: 8px;
			font-family: var(--site-font-mono);
			font-size: 9.5px;
