---
/**
 * MomentGraph.astro — capability-graph moment island (WP-07 production pass
 * over SPIKE-07, PASSED @ 61be832 — see plans/site-redesign/04-discussion.md).
 *
 * Ports ONLY the shell's Bundle-mode visual language (radial edge-bundling,
 * kind-band arcs, hover-to-trace) from
 * `shell/src/shell/claude-config/analyze/graph-view.tsx` — no React, no
 * zoom/drag/force/dag modes, no `deriveGraph`.
 *
 * SSG-first: the radial layout (d3-hierarchy `cluster` + d3-shape
 * `lineRadial`/`curveBundle`) runs HERE, at `astro build` time, in Node.
 * The full SVG — every arc, path, and text label — ships as static markup.
 * There is ZERO client JS required to see the complete graph; `moment-graph.ts`
 * only adds hover/focus-to-trace and an optional ambient draw-in, both gated
 * so the static frame is also the correct reduced-motion frame (island
 * contract: ./CONTRACT.md).
 *
 * Honesty: every node/edge comes from ./graph-fixture.ts, which derives
 * strictly from the vendored ./cast.json (registry-verified — see that
 * file's header comment and the spike report for the node-count drift note).
 *
 * Tone (per CONTRACT.md, locked at G-MOMENT): the shell/stage recreation is a
 * tone-INDEPENDENT dark app object and never flips — only the outer copy
 * (h2/sub/foot) is tone-aware via `--site-*`. What WP-07 changed: the stage's
 * internal near-black/neutral literals are now named `--moment-*` custom
 * properties (mirroring MomentHero's block) instead of scattered magic hsl()
 * literals, so the "graph tokens" are a single documented surface — same
 * spirit as re-deriving from tokens, without breaking the locked contract.
 * Contrast was verified both poles (see WP-07 report): the stage's own
 * palette is fixed, so its internal contrast (node-label-muted on stage-bg,
 * kind-hue text on stage-bg) doesn't change with page tone; the surrounding
 * `--site-*` copy was checked against both the dark and parchment poles.
 *
 * Packaging: client script stays under the small-asset inlining threshold
 * Astro applies automatically (measured 753 B gz inline in the page HTML,
 * 8x under the 6KB budget) — kept inline by not doing anything to force a
 * separate chunk; a hashed chunk only pays off once this script grows enough
 * to amortize an extra request, which isn't the case here.
 */
import { cluster, hierarchy, type HierarchyNode } from 'd3-hierarchy';
import { arc as d3arc, curveBundle, lineRadial } from 'd3-shape';
import {
	graphFixture,
	KIND_COLOR,
	KIND_LABEL,
	KIND_ORDER,
	REL_KIND,
	type GraphEdge,
	type GraphKind,
	type GraphNode,
} from './graph-fixture';

export interface Props {
	/** Tone pole for the outer copy only (headline/sub/foot) — same contract
	 * as MomentHero; the graph stage itself is a tone-independent dark object. */
	tone?: 'dark' | 'light';
}
const { tone = 'dark' } = Astro.props;

// ── build-time radial-bundle layout (ports BundleRenderer's layout memo) ──
const SIZE = 640;
const R = SIZE / 2 - 92;

type BundleDatum = { name: string; kind?: GraphKind; node?: GraphNode; children?: BundleDatum[] };

const groups: BundleDatum[] = KIND_ORDER.map((k) => ({
	name: k,
	kind: k,
	children: graphFixture.nodes.filter((n) => n.kind === k).map((n) => ({ name: n.id, kind: k, node: n })),
})).filter((g) => (g.children?.length ?? 0) > 0);

const root = hierarchy<BundleDatum>({ name: 'root', children: groups }).sort((a, b) =>
	(a.data.node?.label ?? a.data.name).localeCompare(b.data.node?.label ?? b.data.name),
);
cluster<BundleDatum>().size([360, R])(root);
const leaves = root.leaves();
const leafById = new Map<string, HierarchyNode<BundleDatum>>();
for (const l of leaves) if (l.data.node) leafById.set(l.data.node.id, l);

const line = lineRadial<HierarchyNode<BundleDatum>>()
	.curve(curveBundle.beta(0.78))
	.radius((d) => d.y ?? 0)
	.angle((d) => ((d.x ?? 0) * Math.PI) / 180);

const links = graphFixture.edges
	.map((e) => {
		const s = leafById.get(e.source);
		const t = leafById.get(e.target);
		if (!s || !t) return null;
		return { edge: e, d: line(s.path(t)) ?? '' };
	})
	.filter((x): x is { edge: GraphEdge; d: string } => x !== null);

const bandArc = d3arc<{ a0: number; a1: number }>()
	.innerRadius(R + 14)
	.outerRadius(R + 18)
	.startAngle((d) => ((d.a0 - 3) * Math.PI) / 180)
	.endAngle((d) => ((d.a1 + 3) * Math.PI) / 180);

/**
 * Label declutter (WP-07, fixes the engine-band collision visible at 11
 * nodes): a naive `mid = (a0+a1)/2` label angle coincides EXACTLY with a
 * node's own angle whenever a band has an odd member count (the cluster
 * layout spaces children evenly, so the middle child sits at the true
 * midpoint) or exactly one member (a0 === a1 === that node's angle). At
 * that shared angle the band label's fixed-radius text lands right inside
 * the reach of the coincident node's own (much longer) tangential label —
 * see the ENGINES/`pkg-engine-codex` collision in the spike capture.
 *
 * Fix: bias the label angle off any node's exact angle — for odd counts,
 * nudge by half the local inter-node gap so it falls *between* the middle
 * node and its neighbor; for a single-member band, nudge by a small fixed
 * offset. Even counts already land between two nodes, untouched. This is
 * angle-count-general, so it holds as the cast densifies toward ~25 nodes.
 */
const ARC_LABEL_SOLO_NUDGE_DEG = 6;

const arcs = (root.children ?? []).map((g) => {
	const xs = (g.children ?? []).map((c) => c.x ?? 0).sort((a, b) => a - b);
	const a0 = xs[0] ?? 0;
	const a1 = xs[xs.length - 1] ?? 0;
	const count = xs.length;
	const gap = count > 1 ? (a1 - a0) / (count - 1) : 0;
	const mid =
		count <= 1
			? a0 + ARC_LABEL_SOLO_NUDGE_DEG
			: count % 2 === 1
				? (a0 + a1) / 2 + gap / 2
				: (a0 + a1) / 2;
	return { kind: g.data.kind as GraphKind, a0, a1, mid };
});

function degree(id: string): number {
	return graphFixture.edges.filter((e) => e.source === id || e.target === id).length;
}

/** Hub = a node dense enough in links that its label earns mobile real
 * estate; leaves fold their label away below ~720px (arcs + circles stay —
 * see the responsive rule in <style>). Threshold picked against today's
 * fixture (mcp-iyke:7, /release-status:4, pkg-tasks:3 vs. everything else
 * ≤2) and stays meaningful as the cast densifies — hubs are always the
 * minority by construction of a capability graph. */
const HUB_DEGREE = 3;

/** Display-only shortening (drops the `@ikenga/` scope) so long registry
 * names don't collide at this canvas size. The full name still ships in
 * `label`/`aria-label` — nothing is truncated for accessibility, only the
 * on-canvas <text>. */
function shortLabel(label: string): string {
	return label.replace(/^@ikenga\//, '');
}

// Stable, build-time ids for the <title>/<desc> pair — this island only ever
// mounts once per page (moment-lab previews it beside the hero; production
// mounts one instance), so a fixed literal is fine and keeps SSR output
// deterministic (no per-render random suffix to fight caching/diffing).
const titleId = 'mg-title';
const descId = 'mg-desc';
---

<section class="mg" data-moment="graph" data-tone={tone === 'light' ? 'light' : undefined}>
	<div class="mg-copy">
		<h2 class="mg-h2">Everything connects.</h2>
		<p class="mg-sub">
			Skills, commands, MCPs, engines, and installed pkgs — one capability graph,
			radial-bundled the same way the shell renders it.
		</p>
	</div>

	<div class="mg-stage">
		<svg
			class="mg-svg"
			role="img"
			aria-labelledby={`${titleId} ${descId}`}
			viewBox={`0 0 ${SIZE} ${SIZE}`}
			preserveAspectRatio="xMidYMid meet"
		>
			<title id={titleId}>Ikenga capability graph</title>
			<desc id={descId}>
				{`Radial-bundle diagram of ${graphFixture.nodes.length} real, shipping capabilities -- skills, commands, MCPs, engines, and installed pkgs -- grouped into ${arcs.length} kind bands and joined by ${graphFixture.edges.length} links. Every node is keyboard-focusable via Tab; focusing or hovering one highlights its outgoing links in amber and incoming links in teal.`}
			</desc>
			<g transform={`translate(${SIZE / 2},${SIZE / 2})`}>
				{arcs.map((a) => {
					const rad = ((a.mid - 90) * Math.PI) / 180;
					const lr = R + 30;
					const band = bandArc(a) ?? undefined;
					return (
						<g class="mg-arc">
							{band && <path d={band} fill={KIND_COLOR[a.kind]} opacity={0.55} />}
							<text
								x={Math.cos(rad) * lr}
								y={Math.sin(rad) * lr}
								text-anchor="middle"
								dominant-baseline="middle"
								class="mg-arc-label"
								fill={KIND_COLOR[a.kind]}
							>
								{KIND_LABEL[a.kind].toUpperCase()}
							</text>
						</g>
					);
				})}

				<g fill="none">
					{links.map(({ edge, d }) => (
						<path
							class="mg-edge"
							d={d}
							data-source={edge.source}
							data-target={edge.target}
							stroke={KIND_COLOR[REL_KIND[edge.rel]]}
							stroke-width="1.1"
							stroke-dasharray={edge.derivation === 'heuristic' ? '4,4' : undefined}
						/>
					))}
				</g>

				{leaves.map((leaf) => {
					const n = leaf.data.node;
					if (!n) return null;
					const angle = leaf.x ?? 0;
					const flip = angle >= 180;
					const deg = degree(n.id);
					const r = 4 + Math.min(5, deg * 0.8);
					return (
						<g
							class="mg-node"
							data-node-id={n.id}
							data-kind={n.kind}
							data-hub={deg >= HUB_DEGREE ? '' : undefined}
							tabindex="0"
							role="button"
							aria-label={`${n.label} — ${KIND_LABEL[n.kind]}, ${deg} connection${deg === 1 ? '' : 's'}. ${n.detail}`}
							transform={`rotate(${angle - 90}) translate(${leaf.y ?? 0},0)`}
						>
							<circle
								r={r}
								style={`--mg-node-r: ${r}px`}
								fill={`color-mix(in srgb, ${KIND_COLOR[n.kind]} 24%, var(--moment-shell-bg, hsl(28, 22%, 2.5%)))`}
								stroke={KIND_COLOR[n.kind]}
								stroke-width="1.5"
							/>
							<text
								class="mg-node-label"
								dy="0.31em"
								x={flip ? -(r + 5) : r + 5}
								text-anchor={flip ? 'end' : 'start'}
								transform={flip ? 'rotate(180)' : undefined}
							>
								{shortLabel(n.label)}
							</text>
						</g>
					);
				})}
			</g>
		</svg>
	</div>

	<p class="mg-foot">
		<span class="mg-hd" aria-hidden="true">◆</span> Staged demo — every node shown is a real, shipping
		capability · hover or tab through a node to trace its links
	</p>
</section>

<style>
	/* ── capability-graph moment (WP-07 production pass over SPIKE-07) ────── */
	.mg {
		--mg-ease: cubic-bezier(0.22, 0.61, 0.16, 1);

		/* --moment-* locals: the D-01 near-black shell-object internals,
		   named as tokens (mirrors MomentHero's block). Fixed across tone
		   poles — per CONTRACT.md the stage recreation is a dark app OBJECT,
		   not page chrome, so it must NOT flip with [data-tone]. */
		--moment-shell-bg: hsl(28, 22%, 2.5%);
		--moment-shell-border: hsl(30 18% 18% / 0.9);
		--moment-node-label: hsl(32, 11%, 62%);
		--moment-node-label-hot: hsl(36, 28%, 92%);
		--moment-accent: hsl(42, 78%, 54%);
		--moment-success: hsl(170, 42%, 54%);

		display: block;
		padding-block: var(--space-8, 32px);
		background: var(--site-bg);
		color: var(--site-fg);
		font-family: var(--site-font-body);
	}

	.mg-copy {
		text-align: center;
		max-width: 60rem;
		margin: 0 auto var(--space-6, 24px);
		padding-inline: var(--space-6, 24px);
	}
	.mg-h2 {
		font-family: var(--site-font-display);
		font-weight: 600;
		font-size: clamp(1.6rem, 3.6vw, 2.4rem);
		line-height: 1.12;
		letter-spacing: -0.01em;
		margin: 0 0 var(--space-3, 12px);
	}
	.mg-sub {
		font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
		color: var(--site-muted);
		max-width: 46ch;
		margin: 0 auto;
		line-height: 1.5;
	}

	/* Box reserved up front — zero CLS. Square canvas; a picture, not a
	   layout that needs to reflow, so no mobile-breakpoint special case. */
	.mg-stage {
		max-width: 42rem;
		margin-inline: auto;
		padding-inline: var(--space-6, 24px);
	}
	.mg-svg {
		display: block;
		width: 100%;
		aspect-ratio: 1 / 1;
		background: var(--moment-shell-bg);
		border: 1px solid var(--moment-shell-border);
		border-radius: var(--radius-lg, 10px);
		box-shadow: 0 32px 80px -28px hsl(0 0% 0% / 0.8);
	}

	.mg-arc-label {
		font: 500 8.5px var(--site-font-mono);
		letter-spacing: 0.16em;
	}

	.mg-edge {
		stroke-opacity: 0.28;
		transition: stroke-opacity 0.2s var(--mg-ease);
	}
	.mg-svg.mg-tracing .mg-edge {
		stroke-opacity: 0.06;
	}
	.mg-edge.mg-edge-out {
		stroke: var(--moment-accent);
		stroke-width: 2;
		stroke-opacity: 0.9;
	}
	.mg-edge.mg-edge-in {
		stroke: var(--moment-success);
		stroke-width: 2;
		stroke-opacity: 0.9;
	}
	.mg-edge.mg-edge-dim {
		stroke-opacity: 0.04;
	}

	.mg-node {
		cursor: pointer;
	}
	.mg-node circle {
		transition: stroke-width 0.15s var(--mg-ease);
	}
	.mg-node-label {
		font: 500 8px var(--site-font-mono);
		fill: var(--moment-node-label);
		transition: fill 0.15s var(--mg-ease);
	}
	.mg-node.mg-node-hot circle {
		stroke-width: 2.5;
	}
	.mg-node.mg-node-hot .mg-node-label {
		fill: var(--moment-node-label-hot);
		font-weight: 600;
	}
	.mg-node.mg-node-dim {
		opacity: 0.18;
	}
	.mg-node:focus-visible circle {
		outline: 2px solid var(--moment-accent);
		outline-offset: 2px;
	}

	.mg-foot {
		text-align: center;
		margin-top: var(--space-5, 20px);
		font-size: 0.8125rem;
		color: var(--site-faint);
		padding-inline: var(--space-6, 24px);
	}
	.mg-hd {
		color: var(--site-accent);
	}

	/* ── Responsive simplify (WP-07): below ~720px the canvas itself still
	   scales down via the 100%-width/1:1-aspect box above, so raw px values
	   (node circle r, font-size) shrink right along with it. Compensate by
	   bumping both relatively bigger, and declutter by dropping non-hub node
	   labels (arcs, kind-band labels, and all edges/nodes stay — only the
	   long tangential leaf labels that are most prone to crowding go). Hub
	   nodes (data-hub, degree >= HUB_DEGREE) keep their label as the
	   surviving orientation cues. ─────────────────────────────────────────── */
	@media (max-width: 720px) {
		.mg-node circle {
			r: calc(var(--mg-node-r, 4px) * 1.4);
		}
		.mg-arc-label {
			font-size: 10px;
		}
		.mg-node-label {
			font-size: 9.5px;
		}
		.mg-node:not([data-hub]) .mg-node-label {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.mg-edge,
		.mg-node circle,
		.mg-node-label {
			transition: none;
		}
	}
</style>

<script>
	import './moment-graph';
</script>
