---
/**
 * MomentTasks.astro — the tasks/agenda beat (WP-06 · WP-14 hybrid).
 *
 * DEC-8 hybrid retrofit: the pane PIXELS are a real capture of the running
 * Tasks pkg's Agenda view (`/assets/shell/tasks-shell-*.{avif,webp}`, cropped
 * from the WP-11 staged-cast session — Sunday Jul 5, one overdue task pulled
 * forward above two scheduled, the live "now" line). The DOM theatre survives
 * as the tone-aware copy, the framed pane, and two overlays that demonstrably
 * match the real surface: a highlight ring settles on the overdue card and a
 * spark rides the real now-line. No DOM recreation of rows/checkboxes — the
 * capture is the agenda.
 *
 * Colour contract (unchanged): outer copy reads the tone-aware `--site-*`
 * layer; the pane capture is a tone-independent dark object. Motion + lifecycle
 * live in `./moment-tasks.ts` (on the shared `./timeline.ts` engine). See
 * `./CONTRACT.md`. The frame carries an explicit aspect-ratio → zero CLS; the
 * capture is lazy-loaded.
 *
 * Honesty (G-19/G-21): the agenda is the staged-cast's own launch-week tasks —
 * nothing invented. The ring/spark only draw the eye to real pixels.
 */
import castData from './cast.json';

type Cast = typeof castData;
export interface Props {
	/** Tone pole for the OUTER copy only; the pane capture stays dark. */
	tone?: 'dark' | 'light';
	/** Autoplay policy handed to the timeline engine. */
	autoplay?: 'viewport' | 'immediate' | 'manual';
	/** Fixtures slice — defaults to the vendored cast; a caller may pass another. */
	cast?: Cast;
}
const { tone = 'dark', autoplay = 'viewport', cast = castData } = Astro.props;
// cast referenced for provenance parity with the other moments (SSG-only).
void cast;

const svg = (body: string, opts = 'fill="none" stroke="currentColor" stroke-width="1.6"') =>
	`<svg viewBox="0 0 24 24" ${opts} aria-hidden="true">${body}</svg>`;
const icons = {
	replay: svg(
		'<path d="M19.5 12a7.5 7.5 0 1 1-2.2-5.3" stroke-linecap="round"/><path d="M19.5 3.5V9h-5.4z" fill="currentColor" stroke="none"/>',
	),
	diamond: svg('<path d="M12 3 21 12 12 21 3 12z"/>', 'fill="currentColor"'),
};

const TASKS = '/assets/shell/tasks-shell';
const tasksSrcset = (ext: string) =>
	`${TASKS}-643.${ext} 643w, ${TASKS}-965.${ext} 965w, ${TASKS}-1286.${ext} 1286w`;
const TASKS_SIZES = '(min-width: 800px) 768px, 92vw';
---

<section
	class="mt"
	data-moment="tasks"
	data-autoplay={autoplay}
	data-tone={tone === 'light' ? 'light' : undefined}
>
	<div class="mt-copy">
		<h2 class="mt-h2">Tasks that don't slip.</h2>
		<p class="mt-sub">The agenda fills itself from what's due — overdue work is pulled forward, past the line marked now.</p>
	</div>

	<div class="mt-stage">
		<div
			class="mt-shell"
			aria-label="The Ikenga Tasks pane, Agenda view for Sunday July 5 — an overdue launch task pulled forward above two scheduled tasks, with a live now-line."
		>
			<picture>
				<source type="image/avif" srcset={tasksSrcset('avif')} sizes={TASKS_SIZES} />
				<source type="image/webp" srcset={tasksSrcset('webp')} sizes={TASKS_SIZES} />
				<img
					class="mt-img"
					src={`${TASKS}-965.webp`}
					width="1286"
					height="472"
					loading="lazy"
					decoding="async"
					alt="Screenshot of the Ikenga Tasks Agenda for Sunday, July 5 — an overdue 'Fix the OG card' task pulled forward, then two in-progress launch tasks, above a green now-line."
				/>
			</picture>

			<div class="mt-fx" aria-hidden="true">
				<span class="mt-ring" data-ring style="left:30.4%;top:37%;width:64.4%;height:14%"></span>
				<span class="mt-nowline" data-nowline style="left:25.5%;top:83.1%;width:68.3%">
					<span class="mt-spark" data-spark></span>
				</span>
			</div>
		</div>

		<div class="mt-foot">
			<span class="mt-honest"><span class="mt-hd" set:html={icons.diamond} /> Real capture of the Tasks pkg — ships today</span>
			<button class="mt-replay" data-replay type="button"><span class="mt-ri" set:html={icons.replay} /> replay</button>
		</div>
	</div>
</section>

<style>
	/* ── Moment island: tasks/agenda beat (WP-14 hybrid) ──────────────────── */
	.mt {
		--mt-ease: cubic-bezier(0.22, 0.61, 0.16, 1);
		--moment-shell-bg: hsl(28, 22%, 2.5%);
		--moment-shell-border: hsl(30 18% 18% / 0.9);
		--moment-accent: hsl(42, 78%, 54%);
		--moment-success: hsl(170, 42%, 54%);

		display: block;
		padding-block: var(--space-8, 32px);
		background: var(--site-bg);
		color: var(--site-fg);
		font-family: var(--site-font-body);
	}

	.mt-copy {
		text-align: center;
		max-width: 60rem;
		margin: 0 auto var(--space-6, 24px);
		padding-inline: var(--space-6, 24px);
	}
	.mt-h2 {
		font-family: var(--site-font-display);
		font-weight: 600;
		font-size: clamp(1.6rem, 3.6vw, 2.4rem);
		line-height: 1.12;
		letter-spacing: -0.01em;
		margin: 0 0 var(--space-3, 12px);
	}
	.mt-sub {
		font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
		color: var(--site-muted);
		max-width: 48ch;
		margin: 0 auto;
		line-height: 1.5;
	}

	.mt-stage {
		max-width: 48rem;
		margin-inline: auto;
		padding-inline: var(--space-6, 24px);
	}

	/* Box reserved before the lazy image decodes — zero CLS. Ratio = the crop. */
	.mt-shell {
		position: relative;
		background: var(--moment-shell-bg);
		border: 1px solid var(--moment-shell-border);
		border-radius: var(--radius-lg, 10px);
		overflow: hidden;
		box-shadow: 0 32px 80px -28px hsl(0 0% 0% / 0.8);
		aspect-ratio: 1286 / 472;
	}
	.mt-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top left;
	}

	.mt-fx {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}
	.mt-ring {
		position: absolute;
		border: 1px solid var(--moment-accent);
		border-radius: 8px;
		box-shadow: 0 0 0 1px hsl(42 78% 54% / 0.22), 0 0 20px hsl(42 78% 54% / 0.26);
		opacity: 0;
	}
	/* Track riding the real now-line; the spark travels its full width via
	   `cqw` (container-relative), keeping the motion transform-only. */
	.mt-nowline {
		position: absolute;
		height: 2px;
		container-type: inline-size;
	}
	.mt-spark {
		position: absolute;
		top: 50%;
		left: 0;
		width: 22px;
		height: 22px;
		margin: -11px 0 0 -11px;
		border-radius: 999px;
		background: radial-gradient(circle, hsl(170 60% 72% / 0.85), transparent 68%);
		opacity: 0;
	}

	/* ── foot ─────────────────────────────────────────────────────────────── */
	.mt-foot {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-4, 16px);
		margin-top: var(--space-5, 20px);
		font-size: 0.8125rem;
		color: var(--site-faint);
		flex-wrap: wrap;
		text-align: center;
	}
	.mt-honest {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.mt-hd {
		width: 9px;
		height: 9px;
		color: var(--site-accent);
		display: inline-flex;
	}
	.mt-replay {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font: 500 11px var(--site-font-mono);
		color: var(--site-muted);
		background: none;
		border: 1px solid var(--site-border-strong);
		border-radius: 999px;
		padding: 4px 12px;
		cursor: pointer;
		transition: color 0.2s var(--mt-ease), border-color 0.2s var(--mt-ease);
	}
	.mt-ri {
		width: 12px;
		height: 12px;
		display: inline-flex;
	}
	.mt-replay:hover {
		color: var(--site-accent);
		border-color: var(--site-accent);
	}

	/* ── reduced motion: the clean capture, zero animation ────────────────── */
	@media (prefers-reduced-motion: reduce) {
		.mt-ring,
		.mt-spark {
			opacity: 0 !important;
			transform: none !important;
		}
		.mt-replay {
			transition: none;
		}
	}
</style>

<script>
	import './moment-tasks';
</script>
