---
/**
 * MomentHero.astro — the proving moment island (WP-03 / G-MOMENT · WP-14 hybrid).
 *
 * DEC-8 hybrid retrofit: the shell PIXELS are now a real capture of the running
 * Ikenga workspace (`/assets/shell/hero-shell-*.{avif,webp}`, cropped from the
 * WP-11 staged-cast session — tasks pane ∥ launch-readiness dashboard artifact ∥
 * terminal). The DOM theatre survives as the staged lighting around the frame
 * (tone-aware copy, ember light pool, the framed "window") plus small overlays
 * that demonstrably match the real surface: the three panes power on in
 * sequence and a highlight ring settles on the assembled artifact. No DOM
 * recreation of shell content — the founder's R5 complaint (recreated panes
 * don't read as the real app) is answered by using the real app.
 *
 * Colour contract (unchanged): outer copy reads brand intent from the
 * tone-aware `--site-*` layer (flips under [data-tone="light"]); the shell is a
 * tone-INDEPENDENT dark object (now a photographic capture, always the same
 * "window"). The overlay FX use `--moment-*` locals, fixed across poles.
 *
 * Motion + lifecycle live in ./moment-hero.ts (MomentTimeline). See CONTRACT.md.
 * LCP stays the H1 text (DEC-7); the capture is lazy-loaded below it. The frame
 * carries an explicit aspect-ratio so the box is reserved → zero CLS.
 */
import castData from './cast.json';

type Cast = typeof castData;
export interface Props {
	/** Tone pole for the OUTER copy only; the shell capture stays dark. */
	tone?: 'dark' | 'light';
	/** Autoplay policy handed to the timeline engine. */
	autoplay?: 'viewport' | 'immediate' | 'manual';
	/** Fixtures slice — defaults to the vendored cast; a caller may pass another. */
	cast?: Cast;
}
const { tone = 'dark', autoplay = 'viewport', cast = castData } = Astro.props;

const engines = cast.engines_rotation;

// ── inline SVG icon set (currentColor; sized by the consuming rule) ───────
const svg = (body: string, opts = 'fill="none" stroke="currentColor" stroke-width="1.6"') =>
	`<svg viewBox="0 0 24 24" ${opts} aria-hidden="true">${body}</svg>`;
const icons: Record<string, string> = {
	diamond: svg('<path d="M12 3 21 12 12 21 3 12z"/>', 'fill="currentColor"'),
	replay: svg(
		'<path d="M19.5 12a7.5 7.5 0 1 1-2.2-5.3" stroke-linecap="round"/><path d="M19.5 3.5V9h-5.4z" fill="currentColor" stroke="none"/>',
	),
	// Real engine marks (published engines only — G-21). Verbatim from D-01.
	claude:
		'<svg viewBox="0 0 256 257" aria-hidden="true"><path fill="#d97757" d="m50.228 170.321l50.357-28.257l.843-2.463l-.843-1.361h-2.462l-8.426-.518l-28.775-.778l-24.952-1.037l-24.175-1.296l-6.092-1.297L0 125.796l.583-3.759l5.12-3.434l7.324.648l16.202 1.101l24.304 1.685l17.629 1.037l26.118 2.722h4.148l.583-1.685l-1.426-1.037l-1.101-1.037l-25.147-17.045l-27.22-18.017l-14.258-10.37l-7.713-5.25l-3.888-4.925l-1.685-10.758l7-7.713l9.397.649l2.398.648l9.527 7.323l20.35 15.75L94.817 91.9l3.889 3.24l1.555-1.102l.195-.777l-1.75-2.917l-14.453-26.118l-15.425-26.572l-6.87-11.018l-1.814-6.61c-.648-2.723-1.102-4.991-1.102-7.778l7.972-10.823L71.42 0l10.63 1.426l4.472 3.888l6.61 15.101l10.694 23.786l16.591 32.34l4.861 9.592l2.592 8.879l.973 2.722h1.685v-1.556l1.36-18.211l2.528-22.36l2.463-28.776l.843-8.1l4.018-9.722l7.971-5.25l6.222 2.981l5.12 7.324l-.713 4.73l-3.046 19.768l-5.962 30.98l-3.889 20.739h2.268l2.593-2.593l10.499-13.934l17.628-22.036l7.778-8.749l9.073-9.657l5.833-4.601h11.018l8.1 12.055l-3.628 12.443l-11.342 14.388l-9.398 12.184l-13.48 18.147l-8.426 14.518l.778 1.166l2.01-.194l30.46-6.481l16.462-2.982l19.637-3.37l8.88 4.148l.971 4.213l-3.5 8.62l-20.998 5.184l-24.628 4.926l-36.682 8.685l-.454.324l.519.648l16.526 1.555l7.065.389h17.304l32.21 2.398l8.426 5.574l5.055 6.805l-.843 5.184l-12.962 6.611l-17.498-4.148l-40.83-9.721l-14-3.5h-1.944v1.167l11.666 11.406l21.387 19.314l26.767 24.887l1.36 6.157l-3.434 4.86l-3.63-.518l-23.526-17.693l-9.073-7.972l-20.545-17.304h-1.36v1.814l4.73 6.935l25.017 37.59l1.296 11.536l-1.814 3.76l-6.481 2.268l-7.13-1.297l-14.647-20.544l-15.1-23.138l-12.185-20.739l-1.49.843l-7.194 77.448l-3.37 3.953l-7.778 2.981l-6.48-4.925l-3.436-7.972l3.435-15.749l4.148-20.544l3.37-16.333l3.046-20.285l1.815-6.74l-.13-.454l-1.49.194l-15.295 20.999l-23.267 31.433l-18.406 19.702l-4.407 1.75l-7.648-3.954l.713-7.064l4.277-6.286l25.47-32.405l15.36-20.092l9.917-11.6l-.065-1.686h-.583L44.07 198.125l-12.055 1.555l-5.185-4.86l.648-7.972l2.463-2.593l20.35-13.999z"/></svg>',
	codex:
		'<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M22.282 9.821a6 6 0 0 0-.516-4.91a6.05 6.05 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a6 6 0 0 0-3.998 2.9a6.05 6.05 0 0 0 .743 7.097a5.98 5.98 0 0 0 .51 4.911a6.05 6.05 0 0 0 6.515 2.9A6 6 0 0 0 13.26 24a6.06 6.06 0 0 0 5.772-4.206a6 6 0 0 0 3.997-2.9a6.06 6.06 0 0 0-.747-7.073M13.26 22.43a4.48 4.48 0 0 1-2.876-1.04l.141-.081l4.779-2.758a.8.8 0 0 0 .392-.681v-6.737l2.02 1.168a.07.07 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494M3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085l4.783 2.759a.77.77 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646M2.34 7.896a4.5 4.5 0 0 1 2.366-1.973V11.6a.77.77 0 0 0 .388.677l5.815 3.354l-2.02 1.168a.08.08 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.08.08 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667m2.01-3.023l-.141-.085l-4.774-2.782a.78.78 0 0 0-.785 0L9.409 9.23V6.897a.07.07 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.8.8 0 0 0-.393.681zm1.097-2.365l2.602-1.5l2.607 1.5v2.999l-2.597 1.5l-2.607-1.5Z"/></svg>',
	gemini:
		'<svg viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="mh-gg" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="#4285f4"/><stop offset="1" stop-color="#9cbfff"/></linearGradient></defs><path fill="url(#mh-gg)" d="M11.04 19.32Q12 21.51 12 24q0-2.49.93-4.68q.96-2.19 2.58-3.81t3.81-2.55Q21.51 12 24 12q-2.49 0-4.68-.93a12.3 12.3 0 0 1-3.81-2.58a12.3 12.3 0 0 1-2.58-3.81Q12 2.49 12 0q0 2.49-.96 4.68q-.93 2.19-2.55 3.81a12.3 12.3 0 0 1-3.81 2.58Q2.49 12 0 12q2.49 0 4.68.96q2.19.93 3.81 2.55t2.55 3.81"/></svg>',
};
const engineIcon: Record<string, string> = {
	'Claude Code': icons.claude,
	Codex: icons.codex,
	'Gemini CLI': icons.gemini,
};
const engineMono: Record<string, boolean> = { Codex: true };

// ── capture asset (WP-11 export; cropped app frame, 1680×1050) ────────────
const HERO = '/assets/shell/hero-shell';
const heroSrcset = (ext: string) =>
	`${HERO}-840.${ext} 840w, ${HERO}-1260.${ext} 1260w, ${HERO}-1680.${ext} 1680w`;
const HERO_SIZES = '(min-width: 1088px) 1056px, 92vw';
---

<section
	class="mh"
	data-moment="hero"
	data-autoplay={autoplay}
	data-tone={tone === 'light' ? 'light' : undefined}
>
	<div class="mh-copy">
		<h1 class="mh-h1">
			Give <span class="mh-rot" data-rot>{
				engines.map((name, i) => (
					<span class:list={['mh-slot', i === 0 && 'cur']}>
						<span class:list={['mh-eic', engineMono[name] && 'mono']} set:html={engineIcon[name]} />
						<span class="mh-nm">{name}</span>
					</span>
				))
			}</span> <em>a home.</em>
		</h1>
		<p class="mh-sub">Your agents, skills, and running work — one desktop workspace, on your machine.</p>
		<div class="mh-ghost">
			<a href="#install">Download <span class="mh-arr">↓</span></a>
			<a href="#skills">Or start with a skill</a>
		</div>
	</div>

	<div class="mh-stage">
		<div
			class="mh-shell"
			aria-label="The Ikenga workspace running a launch-week project: a Tasks pane, a v0.3 launch-readiness dashboard artifact, and a terminal session side by side."
		>
			<picture>
				<source type="image/avif" srcset={heroSrcset('avif')} sizes={HERO_SIZES} />
				<source type="image/webp" srcset={heroSrcset('webp')} sizes={HERO_SIZES} />
				<img
					class="mh-img"
					src={`${HERO}-1260.webp`}
					width="1680"
					height="1050"
					loading="lazy"
					decoding="async"
					alt="Screenshot of the Ikenga desktop workspace — a Tasks pane with an overdue launch task selected, a v0.3 launch-readiness dashboard artifact, and a terminal session, arranged in split panes."
				/>
			</picture>

			<!-- Overlay theatre: pixels are the capture; these only light the real
			     regions (transform/opacity, aria-hidden). Off by default → the
			     no-JS / reduced-motion frame is the clean capture. -->
			<div class="mh-fx" aria-hidden="true">
				<span class="mh-scrim" data-fx="tasks" style="left:18.4%;top:8.8%;width:40.2%;height:91.2%"></span>
				<span class="mh-scrim" data-fx="art" style="left:58.6%;top:8.8%;width:41.4%;height:44%"></span>
				<span class="mh-scrim" data-fx="term" style="left:58.6%;top:52.8%;width:41.4%;height:47.2%"></span>
				<span class="mh-sweep" data-sweep></span>
				<span class="mh-ring" data-ring style="left:58.6%;top:8.8%;width:41.4%;height:44%"></span>
			</div>
		</div>

		<div class="mh-foot">
			<span class="mh-honest"><span class="mh-hd" set:html={icons.diamond} /> Real capture of the shell — every feature shown ships today</span>
			<button class="mh-replay" data-replay type="button"><span class="mh-ri" set:html={icons.replay} /> replay</button>
		</div>
	</div>
</section>

<style>
	/* ── Moment island: proving moment (D-01 Theatre · WP-14 hybrid) ────────── */
	.mh {
		/* The light-pool pseudo (.mh-stage::before, inset -8% -12%) deliberately
		   bleeds past the stage; without a horizontal clip it widens body
		   scrollWidth to 437px at 390px viewports (WP-15 verify find). Clip at
		   the section — visuals inside are unchanged. */
		overflow-x: clip;
		--mh-ease: cubic-bezier(0.22, 0.61, 0.16, 1);

		/* --moment-* locals used by the overlay FX. Fixed across tone poles —
		   the shell "window" is a dark object, not page chrome. */
		--moment-shell-bg: hsl(28, 22%, 2.5%);
		--moment-shell-border: hsl(30 18% 18% / 0.9);
		--moment-accent: hsl(42, 78%, 54%);

		display: block;
		padding-block: clamp(1.5rem, 4vw, 2.8rem) var(--site-section-pad);
		background: var(--site-bg);
		color: var(--site-fg);
		font-family: var(--site-font-body);
	}

	/* ── Outer copy (tone-aware --site-*) ─────────────────────────────────── */
	.mh-copy {
		text-align: center;
		max-width: 72rem;
		margin: 0 auto var(--space-8, 32px);
		padding-inline: var(--space-6, 24px);
		/* Reserve the copy block so the display-font swap reflow can't displace
		   the (huge, CLS-amplifying) stage below it. */
		min-height: 120px;
	}
	@media (max-width: 640px) {
		.mh-copy {
			min-height: 184px;
		}
	}
	.mh-h1 {
		font-family: var(--site-font-display);
		font-weight: 600;
		font-size: clamp(2.2rem, 5vw, 3.4rem);
		line-height: 1.08;
		letter-spacing: -0.02em;
		margin: 0 0 var(--space-3, 12px);
		text-wrap: balance;
	}
	.mh-h1 em {
		font-style: italic;
		color: var(--site-accent);
		text-shadow: var(--site-glow);
	}
	.mh-rot {
		display: inline-flex;
		align-items: baseline;
		/* Reflow (founder call): the JS fits this span to the CURRENT engine name
		   and eases the width, so the line breathes like the mockups — short
		   names don't leave dead gaps and "a home." tucks against the word. The
		   eased width keeps the per-swap shift small (CLS stays in the good band).
		   Reduced-motion pins the first slot, so no transition fires there. */
		justify-content: center;
		transition: width 340ms var(--mh-ease);
		position: relative;
		vertical-align: baseline;
		white-space: nowrap;
	}
	@media (prefers-reduced-motion: reduce) {
		.mh-rot {
			transition: none;
			width: auto !important; /* natural width of the single shown slot */
		}
	}
	.mh-slot {
		display: inline-flex;
		align-items: baseline;
		gap: 0.22em;
		opacity: 0;
		position: absolute;
		left: 50%;
		/* `translate` (not transform) carries the centering so the rotator's
		   WAAPI transform animations compose with it instead of clobbering it. */
		translate: -50% 0;
		transform: translateY(0.35em);
	}
	.mh-slot.cur {
		position: relative;
		left: auto;
		translate: none;
		opacity: 1;
		transform: none;
	}
	.mh-eic {
		width: 0.72em;
		height: 0.72em;
		align-self: center;
		transform: translateY(0.04em);
		display: inline-flex;
	}
	.mh-eic :global(svg) {
		width: 100%;
		height: 100%;
	}
	.mh-eic.mono {
		color: var(--site-fg);
	}
	.mh-nm {
		font-weight: inherit;
	}
	.mh-sub {
		font-size: clamp(1rem, 1.6vw, 1.1875rem);
		color: var(--site-muted);
		max-width: 52ch;
		margin: 0 auto;
		line-height: 1.5;
	}
	.mh-ghost {
		margin-top: var(--space-5, 20px);
		display: flex;
		gap: var(--space-5, 20px);
		justify-content: center;
		font-size: 0.9375rem;
	}
	.mh-ghost a {
		color: var(--site-muted);
		text-decoration: none;
		border-bottom: 1px solid var(--site-border-strong);
		padding-bottom: 2px;
		transition: color 0.2s var(--mh-ease), border-color 0.2s var(--mh-ease);
	}
	.mh-ghost a:hover {
		color: var(--site-accent);
		border-color: var(--site-accent);
	}
	.mh-arr {
		display: inline-block;
	}

	/* ── Stage + light pool ───────────────────────────────────────────────── */
	.mh-stage {
		position: relative;
		max-width: 72rem;
		margin-inline: auto;
		padding-inline: var(--space-6, 24px);
	}
	.mh-stage::before {
		content: '';
		position: absolute;
		inset: -8% -12% auto;
		height: 90%;
		pointer-events: none;
		background: radial-gradient(
			ellipse 62% 52% at 50% 38%,
			hsl(36 40% 20% / 0.5),
			hsl(28 30% 10% / 0.15) 55%,
			transparent 75%
		);
	}
	/* light pole turns the ember pool off (reads as smudge on parchment) */
	.mh[data-tone='light'] .mh-stage::before {
		background: none;
	}

	/* ── Shell frame (holds the real capture + overlay FX) ────────────────── */
	.mh-shell {
		position: relative;
		max-width: 66rem;
		margin-inline: auto;
		background: var(--moment-shell-bg);
		border: 1px solid var(--moment-shell-border);
		border-radius: var(--radius-lg, 10px);
		overflow: hidden;
		box-shadow: 0 32px 80px -28px hsl(0 0% 0% / 0.8);
		/* CLS: reserve the box before the lazy image decodes. Ratio = the
		   cropped app frame (1680×1050). */
		aspect-ratio: 1680 / 1050;
	}
	.mh-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top left;
	}

	/* overlay layer */
	.mh-fx {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}
	/* Pane scrims darken a real pane region; they lift (opacity→0) in sequence
	   so the panes "power on". Off by default (clean capture); only armed when
	   JS will drive the beat. */
	.mh-scrim {
		position: absolute;
		background: var(--moment-shell-bg);
		opacity: 0;
	}
	.mh[data-anim='js'] .mh-scrim {
		opacity: 0.86;
	}
	/* Diagonal light sweep — a single pass across the frame on play. */
	.mh-sweep {
		position: absolute;
		top: -20%;
		left: 0;
		width: 40%;
		height: 140%;
		opacity: 0;
		transform: translateX(-160%) skewX(-12deg);
		background: linear-gradient(
			100deg,
			transparent,
			hsl(42 80% 66% / 0.1) 45%,
			hsl(42 90% 78% / 0.16) 50%,
			hsl(42 80% 66% / 0.1) 55%,
			transparent
		);
		mix-blend-mode: screen;
	}
	/* Highlight ring — settles on the assembled artifact region. */
	.mh-ring {
		position: absolute;
		border: 1px solid var(--moment-accent);
		border-radius: 8px;
		box-shadow: 0 0 0 1px hsl(42 78% 54% / 0.25), 0 0 22px hsl(42 78% 54% / 0.28);
		opacity: 0;
	}

	/* ── foot ─────────────────────────────────────────────────────────────── */
	.mh-foot {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-4, 16px);
		margin-top: var(--space-5, 20px);
		font-size: 0.8125rem;
		color: var(--site-faint);
		flex-wrap: wrap;
		text-align: center;
	}
	.mh-honest {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.mh-hd {
		width: 9px;
		height: 9px;
		color: var(--site-accent);
		display: inline-flex;
	}
	.mh-replay {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font: 500 11px var(--site-font-mono);
		color: var(--site-muted);
		background: none;
		border: 1px solid var(--site-border-strong);
		border-radius: 999px;
		padding: 4px 12px;
		cursor: pointer;
		transition: color 0.2s var(--mh-ease), border-color 0.2s var(--mh-ease);
	}
	.mh-ri {
		width: 12px;
		height: 12px;
		display: inline-flex;
	}
	.mh-replay:hover {
		color: var(--site-accent);
		border-color: var(--site-accent);
	}

	/* ── reduced motion: the clean capture, zero animation ────────────────── */
	@media (prefers-reduced-motion: reduce) {
		.mh-scrim,
		.mh-sweep,
		.mh-ring {
			opacity: 0 !important;
			transform: none !important;
		}
		.mh-h1 em {
			text-shadow: none;
		}
		.mh-slot {
			display: none;
			position: relative;
		}
		.mh-slot.cur {
			display: inline-flex;
		}
		.mh-ghost a,
		.mh-replay {
			transition: none;
		}
	}
</style>

<script>
	import './moment-hero';
</script>
