---
/**
 * MomentHero.astro — the proving moment island (WP-03 / G-MOMENT).
 *
 * Recreates the locked D-01 "Theatre" hero beat at production fidelity:
 * a one-line headline over a near-full-bleed recreation of the Ikenga shell
 * running `/groundwork status` — panes light up, an artifact assembles, chips
 * settle. All content is imported from `cast.json` at BUILD time (SSG, no
 * runtime fetch), so the DOM ships complete and the reduced-motion / no-JS
 * final frame is correct with zero script.
 *
 * Colour contract:
 *   · outer copy (headline, sub, ghost row, foot) reads brand intent from the
 *     tone-aware `--site-*` layer (flips under [data-tone="light"]);
 *   · the shell is a tone-INDEPENDENT dark app object — every near-black
 *     internal is a `--moment-*` local (the D-01 hardcodes, extracted here),
 *     fixed across poles so the "window" always reads as the same object.
 *
 * Tofu guard: every technical/box-drawing glyph in D-01 (⌗ ▤ ◫ ▦ ⚙ ⚡ ◉ ◐ ▣
 * ◆ ✓ ⟳) is replaced with a tiny inline SVG so no glyph font can tofu.
 *
 * Motion + lifecycle live in ./moment-hero.ts (MomentTimeline). See CONTRACT.md.
 */
import castData from './cast.json';

type Cast = typeof castData;
export interface Props {
	/** Tone pole for the OUTER copy only; the shell stays dark. */
	tone?: 'dark' | 'light';
	/** Autoplay policy handed to the timeline engine. */
	autoplay?: 'viewport' | 'immediate' | 'manual';
	/** Fixtures slice — defaults to the vendored cast; a caller may pass another. */
	cast?: Cast;
}
const { tone = 'dark', autoplay = 'viewport', cast = castData } = Astro.props;

// ── content derived from the cast ─────────────────────────────────────────
const cmd = cast.terminal_transcript.lines[0].text;
const responseLines = cast.terminal_transcript.lines.filter((l) => l.role === 'response');
const engines = cast.engines_rotation;

// ── inline SVG icon set (currentColor; sized by the consuming rule) ───────
const svg = (body: string, opts = 'fill="none" stroke="currentColor" stroke-width="1.6"') =>
	`<svg viewBox="0 0 24 24" ${opts} aria-hidden="true">${body}</svg>`;
const icons: Record<string, string> = {
	brand: svg('<path d="M9 3 7 21M17 3 15 21M3 9h18M3 15h18" stroke-linecap="round"/>'),
	tasks: svg(
		'<rect x="3.5" y="4.5" width="17" height="15" rx="1.6"/><path d="M7.5 9.5h9M7.5 12.5h9M7.5 15.5h5.5" stroke-linecap="round"/>',
	),
	panels: svg('<rect x="3.5" y="4.5" width="17" height="15" rx="1.6"/><path d="M12 4.5v15"/>'),
	store: svg(
		'<rect x="3.5" y="4.5" width="17" height="15" rx="1.6"/><path d="M3.5 12h17M12 4.5v15"/>',
	),
	gear: svg(
		'<circle cx="12" cy="12" r="3.1"/><path d="M12 3v2.4M12 18.6V21M4.2 7.5l2.1 1.2M17.7 15.3l2.1 1.2M4.2 16.5l2.1-1.2M17.7 8.7l2.1-1.2" stroke-linecap="round"/>',
	),
	bolt: svg('<path d="M13 2.5 4.5 13.5H10l-1 8 8.5-11.5H12z"/>', 'fill="currentColor"'),
	scopeAll: svg('<circle cx="12" cy="12" r="7.5"/><circle cx="12" cy="12" r="3.1" fill="currentColor" stroke="none"/>'),
	scopeHalf: svg('<circle cx="12" cy="12" r="7.5"/><path d="M12 4.5a7.5 7.5 0 0 1 0 15z" fill="currentColor" stroke="none"/>'),
	scopeSquare: svg('<rect x="4.5" y="4.5" width="15" height="15" rx="1.4"/><rect x="8.6" y="8.6" width="6.8" height="6.8" fill="currentColor" stroke="none"/>'),
	diamond: svg('<path d="M12 3 21 12 12 21 3 12z"/>', 'fill="currentColor"'),
	check: svg('<path d="M5 12.5 10 17.5 19 6.5" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>'),
	replay: svg(
		'<path d="M19.5 12a7.5 7.5 0 1 1-2.2-5.3" stroke-linecap="round"/><path d="M19.5 3.5V9h-5.4z" fill="currentColor" stroke="none"/>',
	),
	// Real engine marks (published engines only — G-21). Verbatim from D-01.
	claude:
		'<svg viewBox="0 0 256 257" aria-hidden="true"><path fill="#d97757" d="m50.228 170.321l50.357-28.257l.843-2.463l-.843-1.361h-2.462l-8.426-.518l-28.775-.778l-24.952-1.037l-24.175-1.296l-6.092-1.297L0 125.796l.583-3.759l5.12-3.434l7.324.648l16.202 1.101l24.304 1.685l17.629 1.037l26.118 2.722h4.148l.583-1.685l-1.426-1.037l-1.101-1.037l-25.147-17.045l-27.22-18.017l-14.258-10.37l-7.713-5.25l-3.888-4.925l-1.685-10.758l7-7.713l9.397.649l2.398.648l9.527 7.323l20.35 15.75L94.817 91.9l3.889 3.24l1.555-1.102l.195-.777l-1.75-2.917l-14.453-26.118l-15.425-26.572l-6.87-11.018l-1.814-6.61c-.648-2.723-1.102-4.991-1.102-7.778l7.972-10.823L71.42 0l10.63 1.426l4.472 3.888l6.61 15.101l10.694 23.786l16.591 32.34l4.861 9.592l2.592 8.879l.973 2.722h1.685v-1.556l1.36-18.211l2.528-22.36l2.463-28.776l.843-8.1l4.018-9.722l7.971-5.25l6.222 2.981l5.12 7.324l-.713 4.73l-3.046 19.768l-5.962 30.98l-3.889 20.739h2.268l2.593-2.593l10.499-13.934l17.628-22.036l7.778-8.749l9.073-9.657l5.833-4.601h11.018l8.1 12.055l-3.628 12.443l-11.342 14.388l-9.398 12.184l-13.48 18.147l-8.426 14.518l.778 1.166l2.01-.194l30.46-6.481l16.462-2.982l19.637-3.37l8.88 4.148l.971 4.213l-3.5 8.62l-20.998 5.184l-24.628 4.926l-36.682 8.685l-.454.324l.519.648l16.526 1.555l7.065.389h17.304l32.21 2.398l8.426 5.574l5.055 6.805l-.843 5.184l-12.962 6.611l-17.498-4.148l-40.83-9.721l-14-3.5h-1.944v1.167l11.666 11.406l21.387 19.314l26.767 24.887l1.36 6.157l-3.434 4.86l-3.63-.518l-23.526-17.693l-9.073-7.972l-20.545-17.304h-1.36v1.814l4.73 6.935l25.017 37.59l1.296 11.536l-1.814 3.76l-6.481 2.268l-7.13-1.297l-14.647-20.544l-15.1-23.138l-12.185-20.739l-1.49.843l-7.194 77.448l-3.37 3.953l-7.778 2.981l-6.48-4.925l-3.436-7.972l3.435-15.749l4.148-20.544l3.37-16.333l3.046-20.285l1.815-6.74l-.13-.454l-1.49.194l-15.295 20.999l-23.267 31.433l-18.406 19.702l-4.407 1.75l-7.648-3.954l.713-7.064l4.277-6.286l25.47-32.405l15.36-20.092l9.917-11.6l-.065-1.686h-.583L44.07 198.125l-12.055 1.555l-5.185-4.86l.648-7.972l2.463-2.593l20.35-13.999z"/></svg>',
	codex:
		'<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M22.282 9.821a6 6 0 0 0-.516-4.91a6.05 6.05 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a6 6 0 0 0-3.998 2.9a6.05 6.05 0 0 0 .743 7.097a5.98 5.98 0 0 0 .51 4.911a6.05 6.05 0 0 0 6.515 2.9A6 6 0 0 0 13.26 24a6.06 6.06 0 0 0 5.772-4.206a6 6 0 0 0 3.997-2.9a6.06 6.06 0 0 0-.747-7.073M13.26 22.43a4.48 4.48 0 0 1-2.876-1.04l.141-.081l4.779-2.758a.8.8 0 0 0 .392-.681v-6.737l2.02 1.168a.07.07 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494M3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085l4.783 2.759a.77.77 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646M2.34 7.896a4.5 4.5 0 0 1 2.366-1.973V11.6a.77.77 0 0 0 .388.677l5.815 3.354l-2.02 1.168a.08.08 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.08.08 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667m2.01-3.023l-.141-.085l-4.774-2.782a.78.78 0 0 0-.785 0L9.409 9.23V6.897a.07.07 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.8.8 0 0 0-.393.681zm1.097-2.365l2.602-1.5l2.607 1.5v2.999l-2.597 1.5l-2.607-1.5Z"/></svg>',
	gemini:
		'<svg viewBox="0 0 24 24" aria-hidden="true"><defs><linearGradient id="mh-gg" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="#4285f4"/><stop offset="1" stop-color="#9cbfff"/></linearGradient></defs><path fill="url(#mh-gg)" d="M11.04 19.32Q12 21.51 12 24q0-2.49.93-4.68q.96-2.19 2.58-3.81t3.81-2.55Q21.51 12 24 12q-2.49 0-4.68-.93a12.3 12.3 0 0 1-3.81-2.58a12.3 12.3 0 0 1-2.58-3.81Q12 2.49 12 0q0 2.49-.96 4.68q-.93 2.19-2.55 3.81a12.3 12.3 0 0 1-3.81 2.58Q2.49 12 0 12q2.49 0 4.68.96q2.19.93 3.81 2.55t2.55 3.81"/></svg>',
};
const engineIcon: Record<string, string> = {
	'Claude Code': icons.claude,
	Codex: icons.codex,
	'Gemini CLI': icons.gemini,
};
const engineMono: Record<string, boolean> = { Codex: true };

// ── emphasis helpers (deterministic from the cast) ────────────────────────
const esc = (s: string) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[c] as string);
const amberTokens = [cast.project.slug, cast.artifact.filename].filter(Boolean) as string[];
function emphasize(text: string): string {
	let html = esc(text);
	for (const t of amberTokens) {
		html = html.split(esc(t)).join(`<span class="mh-amber">${esc(t)}</span>`);
	}
	// timing badge reads as a success beat (matches D-01)
	html = html.replace(/(done in [\d.]+s)/, '<span class="mh-ok-t">$1</span>');
	return html;
}
function artItem(item: string): string {
	const e = esc(item);
	const m = e.match(/^(\S+)(.*)$/s);
	let html = m ? `<b>${m[1]}</b>${m[2]}` : e;
	html = html.replace(/\bozi\b/, '<i>ozi</i>'); // lore touch, italic
	return html;
}

const boardMap: Record<string, { dot: string; chip: string; label: string }> = {
	done: { dot: 'g', chip: 'done', label: 'done' },
	review: { dot: 'a', chip: 'rev', label: 'review' },
	queued: { dot: 'dim', chip: 'q', label: 'queued' },
};
---

<section
	class="mh"
	data-moment="hero"
	data-cmd={cmd}
	data-autoplay={autoplay}
	data-tone={tone === 'light' ? 'light' : undefined}
>
	<div class="mh-copy">
		<h1 class="mh-h1">
			Give <span class="mh-rot" data-rot>{
				engines.map((name, i) => (
					<span class:list={['mh-slot', i === 0 && 'cur']}>
						<span class:list={['mh-eic', engineMono[name] && 'mono']} set:html={engineIcon[name]} />
						<span class="mh-nm">{name}</span>
					</span>
				))
			}</span> <em>a home.</em>
		</h1>
		<p class="mh-sub">Your agents, skills, and running work — one desktop workspace, on your machine.</p>
		<div class="mh-ghost">
			<a href="#install">Download <span class="mh-arr">↓</span></a>
			<a href="#skills">Or start with a skill</a>
		</div>
	</div>

	<div class="mh-stage">
		<div
			class="mh-shell"
			aria-label="Ikenga workspace running a groundwork status check — panes light up as the skill reports and an artifact takes shape."
		>
			<div class="mh-shell-in">
				<!-- activity rail -->
				<div class="mh-rail" aria-hidden="true">
					<i set:html={icons.tasks} />
					<i set:html={icons.panels} />
					<i set:html={icons.store} />
					<span class="mh-sp"></span>
					<i class="on" set:html={icons.brand} />
					<i set:html={icons.gear} />
					<b class="mh-avatar">IK</b>
				</div>

				<!-- sidebar -->
				<div class="mh-sb" aria-hidden="true">
					<div class="mh-sb-brand"><span class="mh-mark" set:html={icons.brand} /> Ikenga <kbd>⌘1</kbd></div>
					<div class="mh-sect">Run</div>
					<div class="mh-item on"><s class="mh-kd skill" set:html={icons.bolt} /> groundwork <kbd>run</kbd></div>
					<div class="mh-item"><s class="mh-kd skill" set:html={icons.bolt} /> artifact-builder</div>
					<div class="mh-item"><s class="mh-kd skill" set:html={icons.bolt} /> release-status</div>
					<div class="mh-sect">Views</div>
					<div class="mh-item"><s class="mh-kd" set:html={icons.tasks} /> Tasks · Agenda</div>
					<div class="mh-item"><s class="mh-kd" set:html={icons.store} /> Ọba (store)</div>
					<div class="mh-sect">Scope</div>
					<div class="mh-scope on"><s class="mh-d" set:html={icons.scopeAll} /> All scopes</div>
					<div class="mh-scope"><s class="mh-d" set:html={icons.scopeHalf} /> Personal</div>
					<div class="mh-scope"><s class="mh-d" set:html={icons.scopeSquare} /> {cast.workspace.scope_label}</div>
				</div>

				<!-- main column -->
				<div class="mh-mn">
					<div class="mh-crumb">
						<b>{cast.workspace.scope_label}</b> <span class="mh-crumb-sep">›</span> {cast.project.slug}
						<span class="mh-chip live">{cast.project.status_chip}</span>
						<span class="mh-sp"></span>
						<span class="mh-path">{cast.project.path}</span>
					</div>

					<div class="mh-panes">
						<div class="mh-pane term">
							<div class="mh-pane-head">
								<span class="mh-n">Terminal</span> · {cast.terminal_transcript.session_label}
								<span class="mh-sp"></span><span class="mh-chip live">session</span>
							</div>
							<div class="mh-pane-body">
								<div class="mh-tline"><span class="mh-p">›</span> <span class="mh-cmd" data-typed>{cmd}</span><span class="mh-cursor" data-cursor></span></div>
								{responseLines.map((l) => (
									<div class="mh-tline mh-m" data-step={l.step}>
										{l.tone === 'ok' && <span class="mh-ok" set:html={icons.check} />}
										<span set:html={emphasize(l.text)} />
									</div>
								))}
							</div>
						</div>

						<div class="mh-pane">
							<div class="mh-pane-head">
								<span class="mh-n">Groundwork</span> · board
								<span class="mh-sp"></span><span class="mh-chip">{cast.board.title} · {cast.board.wps.length}</span>
							</div>
							<div class="mh-pane-body">
								{cast.board.wps.map((wp) => {
									const s = boardMap[wp.status] ?? boardMap.queued;
									return (
										<div class="mh-brow mh-m" data-step="3">
											<span class:list={['mh-dot', s.dot]}></span>
											<span class="mh-id">{wp.id}</span>
											<span class="mh-t">{wp.title}</span>
											<span class:list={['mh-chip', s.chip]}>{s.label}</span>
										</div>
									);
								})}
							</div>
						</div>

						<div class="mh-pane">
							<div class="mh-pane-head">
								<span class="mh-n">Artifact</span> · {cast.artifact.filename}
								<span class="mh-sp"></span><span class="mh-chip done mh-m" data-step="5">{cast.artifact.saved_chip}</span>
							</div>
							<div class="mh-pane-body">
								<div class="mh-art-title mh-m" data-step="4">{cast.artifact.title}</div>
								{cast.artifact.items.map((item) => (
									<div class="mh-ablock mh-m" data-step="4">
										<span class="mh-abd" set:html={icons.diamond} />
										<span class="mh-abt" set:html={artItem(item)} />
									</div>
								))}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="mh-foot">
			<span class="mh-honest"><span class="mh-hd" set:html={icons.diamond} /> Staged demo — every feature shown ships today</span>
			<button class="mh-replay" data-replay type="button"><span class="mh-ri" set:html={icons.replay} /> replay</button>
		</div>
	</div>
</section>

<style>
	/* ── Moment island: proving moment (D-01 Theatre) ─────────────────────── */
	.mh {
		/* Motion ramp — tuned crisper than the board's 0.2,0.6,0.2,1. */
		--mh-ease: cubic-bezier(0.22, 0.61, 0.16, 1);

		/* --moment-* locals: the D-01 near-black shell internals, extracted.
		   Fixed across tone poles — the shell is a dark app OBJECT, not page
		   chrome, so it must NOT flip with [data-tone]. */
		--moment-shell-bg: hsl(28, 22%, 2.5%);
		--moment-shell-border: hsl(30 18% 18% / 0.9);
		--moment-rail-bg: hsl(28, 24%, 1.8%);
		--moment-rail-idle: hsl(28, 10%, 30%);
		--moment-rail-on-bg: hsl(28, 14%, 9%);
		--moment-avatar-ink: hsl(28, 30%, 96%);
		--moment-sb-bg: hsl(28, 16%, 4.5%);
		--moment-sect: hsl(28, 10%, 34%);
		--moment-item-on-bg: hsl(28, 12%, 9.5%);
		--moment-scope-fg: hsl(28, 10%, 42%);
		--moment-scope-on-bg: hsl(28, 12%, 8%);
		--moment-mn-bg: hsl(28, 20%, 3%);
		--moment-crumb-sep: hsl(28, 10%, 28%);
		--moment-crumb-path: hsl(28, 10%, 38%);
		--moment-pane-bg: hsl(28, 20%, 3%);
		--moment-row-bg: hsl(28, 14%, 5%);
		--moment-id: hsl(28, 10%, 38%);
		--moment-head: hsl(28, 10%, 40%);
		--moment-head-n: hsl(28, 10%, 52%);
		--moment-dim-dot: hsl(28, 10%, 26%);
		--moment-fg: hsl(36, 28%, 90%);
		--moment-fg-muted: hsl(32, 11%, 56%);
		--moment-fg-faint: hsl(28, 10%, 44%);
		--moment-border: hsl(28, 14%, 15%);
		--moment-border-soft: hsl(28, 14%, 11%);
		/* Brand semantics INSIDE the shell — fixed dark values (never flip). */
		--moment-accent: hsl(42, 78%, 54%);
		--moment-success: hsl(170, 42%, 54%);
		--moment-ember: hsl(14, 78%, 52%);
		--moment-agent: hsl(262, 45%, 62%);
		--moment-chip-live-bg: hsl(42 48% 12% / 0.5);
		--moment-chip-live-bd: hsl(42, 48%, 24%);
		--moment-chip-done-bg: hsl(170 30% 10% / 0.5);
		--moment-chip-done-bd: hsl(170 42% 30% / 0.7);

		display: block;
		padding-block: clamp(1.5rem, 4vw, 2.8rem) var(--site-section-pad);
		background: var(--site-bg);
		color: var(--site-fg);
		font-family: var(--site-font-body);
	}

	/* ── Outer copy (tone-aware --site-*) ─────────────────────────────────── */
	.mh-copy {
		text-align: center;
		max-width: 72rem;
		margin: 0 auto var(--space-8, 32px);
		padding-inline: var(--space-6, 24px);
	}
	.mh-h1 {
		font-family: var(--site-font-display);
		font-weight: 600;
		font-size: clamp(2.2rem, 5vw, 3.4rem);
		line-height: 1.08;
		letter-spacing: -0.02em;
		margin: 0 0 var(--space-3, 12px);
		text-wrap: balance;
	}
	.mh-h1 em {
		font-style: italic;
		color: var(--site-accent);
		text-shadow: var(--site-glow);
	}
	.mh-rot {
		display: inline-flex;
		align-items: baseline;
		position: relative;
		vertical-align: baseline;
		white-space: nowrap;
	}
	.mh-slot {
		display: inline-flex;
		align-items: baseline;
		gap: 0.22em;
		opacity: 0;
		position: absolute;
		left: 0;
		transform: translateY(0.35em);
	}
	.mh-slot.cur {
		position: relative;
		opacity: 1;
		transform: none;
	}
	.mh-eic {
		width: 0.72em;
		height: 0.72em;
		align-self: center;
		transform: translateY(0.04em);
		display: inline-flex;
	}
	.mh-eic :global(svg) {
		width: 100%;
		height: 100%;
	}
	.mh-eic.mono {
		color: var(--site-fg);
	}
	.mh-nm {
		font-weight: inherit;
	}
	.mh-sub {
		font-size: clamp(1rem, 1.6vw, 1.1875rem);
		color: var(--site-muted);
		max-width: 52ch;
		margin: 0 auto;
		line-height: 1.5;
	}
	.mh-ghost {
		margin-top: var(--space-5, 20px);
		display: flex;
		gap: var(--space-5, 20px);
		justify-content: center;
		font-size: 0.9375rem;
