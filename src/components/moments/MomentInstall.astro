---
/**
 * MomentInstall.astro — the Ọba install beat (WP-06 · WP-14 hybrid).
 *
 * DEC-8 hybrid retrofit: the store PIXELS are a real capture of the running
 * Ngwa/Ọba store (`/assets/shell/install-shell-*.{avif,webp}`, cropped from the
 * WP-11 staged-cast session — the catalog list with `groundwork` selected and
 * its detail panel showing the npx provenance + Install action). The DOM
 * theatre survives as the tone-aware copy, the framed window, and overlays that
 * demonstrably match the real surface: a ring settles on the selected pkg row,
 * a light sweep passes, and the real Install button pulses. No DOM recreation of
 * store rows — the capture is the store.
 *
 * Colour contract (unchanged): outer copy reads the tone-aware `--site-*`
 * layer; the store capture is a tone-independent dark object. Motion + lifecycle
 * live in `./moment-install.ts` (on the shared `./timeline.ts` engine). See
 * `./CONTRACT.md`. Explicit aspect-ratio → zero CLS; the capture is lazy-loaded.
 *
 * Honesty (G-19/G-21): every row in the capture is a registry-published pkg /
 * skill from the staged catalog (`groundwork` selected). The rings/sweep only
 * draw the eye to real pixels — no install state is fabricated.
 */
import castData from './cast.json';

type Cast = typeof castData;
export interface Props {
	/** Tone pole for the OUTER copy only; the store capture stays dark. */
	tone?: 'dark' | 'light';
	/** Autoplay policy handed to the timeline engine. */
	autoplay?: 'viewport' | 'immediate' | 'manual';
	/** Fixtures slice — defaults to the vendored cast; a caller may pass another. */
	cast?: Cast;
}
const { tone = 'dark', autoplay = 'viewport', cast = castData } = Astro.props;
void cast; // referenced for provenance parity with the other moments (SSG-only).

const svg = (body: string, opts = 'fill="none" stroke="currentColor" stroke-width="1.6"') =>
	`<svg viewBox="0 0 24 24" ${opts} aria-hidden="true">${body}</svg>`;
const icons = {
	replay: svg(
		'<path d="M19.5 12a7.5 7.5 0 1 1-2.2-5.3" stroke-linecap="round"/><path d="M19.5 3.5V9h-5.4z" fill="currentColor" stroke="none"/>',
	),
	diamond: svg('<path d="M12 3 21 12 12 21 3 12z"/>', 'fill="currentColor"'),
};

const INSTALL = '/assets/shell/install-shell';
const installSrcset = (ext: string) =>
	`${INSTALL}-840.${ext} 840w, ${INSTALL}-1260.${ext} 1260w, ${INSTALL}-1680.${ext} 1680w`;
const INSTALL_SIZES = '(min-width: 928px) 896px, 92vw';
---

<section
	class="mi"
	data-moment="install"
	data-autoplay={autoplay}
	data-tone={tone === 'light' ? 'light' : undefined}
>
	<div class="mi-copy">
		<h2 class="mi-h2">One click. Installed.</h2>
		<p class="mi-sub">Ọba installs a pkg straight from the store — it resolves to an npx fetch into the vault, no restart, no config file to hand-edit.</p>
	</div>

	<div class="mi-stage">
		<div
			class="mi-shell"
			aria-label="The Ikenga Ọba store — the catalog with the groundwork skill selected, its detail panel showing npx provenance and an Install action."
		>
			<picture>
				<source type="image/avif" srcset={installSrcset('avif')} sizes={INSTALL_SIZES} />
				<source type="image/webp" srcset={installSrcset('webp')} sizes={INSTALL_SIZES} />
				<img
					class="mi-img"
					src={`${INSTALL}-1260.webp`}
					width="1680"
					height="1050"
					loading="lazy"
					decoding="async"
					alt="Screenshot of the Ikenga Ọba store — a catalog of skills with 'groundwork' selected, its detail panel showing source npx, ref royalti-io/groundwork, version 0.1.0, and an Install button."
				/>
			</picture>

			<div class="mi-fx" aria-hidden="true">
				<span class="mi-ring" data-ring="row" style="left:19.2%;top:41.5%;width:16.3%;height:7.2%"></span>
				<span class="mi-ring" data-ring="btn" style="left:35.9%;top:92.6%;width:5.9%;height:5.9%"></span>
				<span class="mi-sweep" data-sweep></span>
			</div>
		</div>

		<div class="mi-foot">
			<span class="mi-honest"><span class="mi-hd" set:html={icons.diamond} /> Real capture of the Ọba store — groundwork is a registry-published skill</span>
			<button class="mi-replay" data-replay type="button"><span class="mi-ri" set:html={icons.replay} /> replay</button>
		</div>
	</div>
</section>

<style>
	/* ── Moment island: Ọba install beat (WP-14 hybrid) ───────────────────── */
	.mi {
		--mi-ease: cubic-bezier(0.22, 0.61, 0.16, 1);
		--moment-shell-bg: hsl(28, 22%, 2.5%);
		--moment-shell-border: hsl(30 18% 18% / 0.9);
		--moment-accent: hsl(42, 78%, 54%);

		display: block;
		padding-block: var(--space-8, 32px);
		background: var(--site-bg);
		color: var(--site-fg);
		font-family: var(--site-font-body);
	}

	.mi-copy {
		text-align: center;
		max-width: 60rem;
		margin: 0 auto var(--space-6, 24px);
		padding-inline: var(--space-6, 24px);
	}
	.mi-h2 {
		font-family: var(--site-font-display);
		font-weight: 600;
		font-size: clamp(1.6rem, 3.6vw, 2.4rem);
		line-height: 1.12;
		letter-spacing: -0.01em;
		margin: 0 0 var(--space-3, 12px);
	}
	.mi-sub {
		font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
		color: var(--site-muted);
		max-width: 52ch;
		margin: 0 auto;
		line-height: 1.5;
	}

	.mi-stage {
		max-width: 56rem;
		margin-inline: auto;
		padding-inline: var(--space-6, 24px);
	}

	/* Box reserved before the lazy image decodes — zero CLS. Ratio = the crop. */
	.mi-shell {
		position: relative;
		background: var(--moment-shell-bg);
		border: 1px solid var(--moment-shell-border);
		border-radius: var(--radius-lg, 10px);
		overflow: hidden;
		box-shadow: 0 32px 80px -28px hsl(0 0% 0% / 0.8);
		aspect-ratio: 1680 / 1050;
	}
	.mi-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top left;
	}

	.mi-fx {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}
	.mi-ring {
		position: absolute;
		border: 1px solid var(--moment-accent);
		border-radius: 8px;
		box-shadow: 0 0 0 1px hsl(42 78% 54% / 0.22), 0 0 20px hsl(42 78% 54% / 0.26);
		opacity: 0;
	}
	.mi-ring[data-ring='btn'] {
		border-radius: 6px;
	}
	.mi-sweep {
		position: absolute;
		top: -20%;
		left: 0;
		width: 38%;
		height: 140%;
		opacity: 0;
		transform: translateX(-160%) skewX(-12deg);
		background: linear-gradient(
			100deg,
			transparent,
			hsl(42 80% 66% / 0.09) 45%,
			hsl(42 90% 78% / 0.15) 50%,
			hsl(42 80% 66% / 0.09) 55%,
			transparent
		);
		mix-blend-mode: screen;
	}

	/* ── foot ─────────────────────────────────────────────────────────────── */
	.mi-foot {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-4, 16px);
		margin-top: var(--space-5, 20px);
		font-size: 0.8125rem;
		color: var(--site-faint);
		flex-wrap: wrap;
		text-align: center;
	}
	.mi-honest {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.mi-hd {
		width: 9px;
		height: 9px;
		color: var(--site-accent);
		display: inline-flex;
	}
	.mi-replay {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font: 500 11px var(--site-font-mono);
		color: var(--site-muted);
		background: none;
		border: 1px solid var(--site-border-strong);
		border-radius: 999px;
		padding: 4px 12px;
		cursor: pointer;
		transition: color 0.2s var(--mi-ease), border-color 0.2s var(--mi-ease);
	}
	.mi-ri {
		width: 12px;
		height: 12px;
		display: inline-flex;
	}
	.mi-replay:hover {
		color: var(--site-accent);
		border-color: var(--site-accent);
	}

	/* ── reduced motion: the clean capture, zero animation ────────────────── */
	@media (prefers-reduced-motion: reduce) {
		.mi-ring,
		.mi-sweep {
			opacity: 0 !important;
			transform: none !important;
		}
		.mi-replay {
			transition: none;
		}
	}
</style>

<script>
	import './moment-install';
</script>
